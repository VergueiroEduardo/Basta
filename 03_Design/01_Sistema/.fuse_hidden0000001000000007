<div class="register-page">

  <!-- ── SIDEBAR ─────────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar__logo">
      <svg style="color: var(--white)" aria-label="Basta." role="img" viewBox="0 0 602.25 254.23"><use href="#logo-basta"/></svg>
    </div>

  </aside>

  <!-- ── FORM AREA ───────────────────────────────────────── -->
  <main class="form-area" id="form-redefinir">
    <div class="form-container">

      <!-- ── ESTADO 1: FORMULÁRIO ──────────────────────────── -->
      <div class="state-form">

        <div class="form-header">
          <h1 class="form-title">Estamos quase lá.</h1>
          <p class="form-subtitle">Crie uma nova senha e volte a acessar sua conta.</p>
        </div>

        <form novalidate id="reset-form" onsubmit="event.preventDefault(); if(validatePasswordReset()) handlePasswordReset()">
          <div class="form-core">

            <div class="form-fields-block">

              <div class="form-group">
                <label class="form-label" for="nova-senha">Nova senha</label>
                <div class="input-password-wrap">
                  <input
                    type="password"
                    id="nova-senha"
                    class="form-input"
                    placeholder="Mínimo 8 caracteres"
                    autocomplete="new-password"
                  >
                  <button
                    type="button"
                    class="password-toggle"
                    id="toggle-nova"
                    aria-label="Mostrar senha"
                    onclick="togglePassword('nova-senha', 'toggle-nova')"
                  >
                    <!-- Olho fechado (mostrar) -->
                    <svg class="toggle-icon-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                    <!-- Olho riscado (ocultar) -->
                    <svg class="toggle-icon-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                      <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                      <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                  </button>
                </div>
                <div class="form-error" id="nova-senha-error" hidden>
                  <svg class="form-error__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                  <span>Mínimo de 8 caracteres.</span>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="confirmar-senha">Confirmar nova senha</label>
                <div class="input-password-wrap">
                  <input
                    type="password"
                    id="confirmar-senha"
                    class="form-input"
                    placeholder="Repita a senha"
                    autocomplete="new-password"
                  >
                  <button
                    type="button"
                    class="password-toggle"
                    id="toggle-confirmar"
                    aria-label="Mostrar senha"
                    onclick="togglePassword('confirmar-senha', 'toggle-confirmar')"
                  >
                    <svg class="toggle-icon-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                    <svg class="toggle-icon-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                      <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                      <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                  </button>
                </div>
                <div class="form-error" id="confirmar-senha-error" hidden>
                  <svg class="form-error__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                  <span>As senhas não coincidem.</span>
                </div>
              </div>

            </div>

            <div class="form-cta">
              <button type="submit" class="btn btn-primary" id="submit-btn" aria-disabled="false">
                <span class="btn__text">Redefinir senha <span class="btn__arrow">&rarr;</span></span>
              </button>
            </div>

          </div>
        </form>

        <p class="form-login-link">
          Lembrou a senha? <a href="03_basta-login.html">Entrar</a>
        </p>

      </div>

      <!-- ── ESTADO 2: SENHA REDEFINIDA ─────────────────────── -->
      <div class="state-success">

        <div class="status-icon status-icon--green">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>

        <h2 class="status-title">Senha redefinida<span>.</span></h2>
        <p class="status-text">
          Sua nova senha foi salva com sucesso. Agora é só entrar na sua conta.
        </p>

        <a href="03_basta-login.html" class="btn btn-primary">
          Entrar na conta <span class="btn__arrow">&rarr;</span>
        </a>

      </div>

      <!-- ── ESTADO 3: LINK EXPIRADO ────────────────────────── -->
      <div class="state-expired">

        <div class="status-icon status-icon--error">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </div>

        <h2 class="status-title" style="margin-bottom: 12px;">Link expirado.</h2>
        <p class="status-text">
          Este link de redefinição não é mais válido. Links expiram após 15 minutos por segurança.
        </p>

        <a href="04_basta-recuperar-senha.html" class="btn btn-primary">
          Solicitar novo link <span class="btn__arrow">&rarr;</span>
        </a>

        <p class="form-login-link">
          Lembrou a senha? <a href="03_basta-login.html">Entrar</a>
        </p>

      </div>

    </div>
  </main>

</div>

<script>
  /* ── FORM VALIDATION ────────────────────────────────────── */
  function validateField(fieldId, isValid, errorMsg = '') {
    const field = document.getElementById(fieldId);
    const errorEl = document.getElementById(fieldId + '-error');

    if (!isValid) {
      field.classList.add('form-input--error');
      if (errorEl) {
        errorEl.removeAttribute('hidden');
        if (errorMsg) errorEl.querySelector('span').textContent = errorMsg;
      }
      return false;
    } else {
      field.classList.remove('form-input--error');
      if (errorEl) errorEl.setAttribute('hidden', '');
      return true;
    }
  }

  function validatePasswordReset() {
    const novaSenha = document.getElementById('nova-senha').value;
    const confirmar = document.getElementById('confirmar-senha').value;

    let isValid = true;

    isValid = validateField('nova-senha', novaSenha.length >= 8, 'Mínimo de 8 caracteres.') && isValid;
    isValid = validateField('confirmar-senha', novaSenha === confirmar && novaSenha.length >= 8, 'As senhas não coincidem.') && isValid;

    return isValid;
  }

  // Validação no blur de cada campo
  document.getElementById('nova-senha')?.addEventListener('blur', function() {
    if (this.value) {
      validateField('nova-senha', this.value.length >= 8, 'Mínimo de 8 caracteres.');
    }
  });

  document.getElementById('confirmar-senha')?.addEventListener('blur', function() {
    const novaSenha = document.getElementById('nova-senha').value;
    if (this.value) {
      validateField('confirmar-senha', novaSenha === this.value && novaSenha.length >= 8, 'As senhas não coincidem.');
    }
  });

  /* ── PASSWORD TOGGLE ──────────────────────────────────────── */
  function togglePassword(inputId, toggleId) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(toggleId);
    const isVisible = input.type === 'text';

    input.type = isVisible ? 'password' : 'text';
    btn.classList.toggle('is-visible', !isVisible);
    btn.setAttribute('aria-label', isVisible ? 'Mostrar senha' : 'Ocultar senha');
  }

  /* ── FORM SUBMIT ──────────────────────────────────────────── */
  const form = document.getElementById('reset-form');
  const submitBtn = document.getElementById('submit-btn');
  const stateForm = document.querySelector('.state-form');
  const stateSuccess = document.querySelector('.state-success');

  function handlePasswordReset() {
    // Loading
    submitBtn.classList.add('btn--loading');
    submitBtn.disabled = true;

    // Simula chamada de API (1.2s)
    setTimeout(() => {
      stateForm.classList.add('is-hidden');
      stateSuccess.classList.add('is-active');
    }, 1200);
  }

  /* ── SIMULAÇÃO: estado de link expirado (para testes) ──────
     Para testar o estado de link expirado, adicione ?expired=1 na URL.
     Ex: 05_basta-redefinir-senha.html?expired=1
  ──────────────────────────────────────────────────────────── */
  (function checkToken() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('expired') === '1') {
      stateForm.classList.add('is-hidden');
      document.querySelector('.state-expired').classList.add('is-active');
    }
  })();
</script>

