<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Basta. — Redefinir Senha</title>
  <meta name="description" content="Crie uma nova senha e recupere o acesso à sua conta Basta." />
  <meta name="theme-color" content="#1A1A1A" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- BASTA FOUNDATION INJECTED -->
  <link rel="stylesheet" href="_foundation/tokens.css" />
  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_components/btn.css" />
  <link rel="stylesheet" href="_components/form.css" />
  <style>

    /* ── RESET ──────────────────────────────────────────────── */    body {
      font-family: var(--f);
      font-size: 18px;
      line-height: 1.6;
      color: var(--black);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    input { font-family: inherit; }
    :where(button, a, input, select, textarea) { border-radius: 0; -webkit-appearance: none; }

    /* ── ACESSIBILIDADE ─────────────────────────────────────── */
    .skip-link {
      position: absolute; top: -6rem; left: 24px;
      background: var(--green); color: var(--white);
      font-size: 14px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 14px 24px; z-index: 9999; transition: top var(--t);
    }
    .skip-link:focus { top: 1rem; }    /* ── LAYOUT PRINCIPAL ───────────────────────────────────── */
    .register-page {
      display: flex;
      min-height: 100vh;
      min-height: 100dvh;
    }

    /* ── SIDEBAR ────────────────────────────────────────────── */
    .sidebar {
      width: 440px;
      background: var(--black);
      color: var(--white);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 48px;
      flex-shrink: 0;
      position: relative;
      overflow: hidden;
    }

    .sidebar__logo { margin-bottom: 48px; }

    .sidebar__headline {
      font-size: clamp(32px, 3.5vw, 48px);
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .sidebar__headline-accent { color: var(--white); }

    .sidebar__subtext {
      font-size: 15px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.6;
      max-width: 300px;
    }

    .sidebar::after { display: none; }

    /* ── FORM AREA ──────────────────────────────────────────── */
    /* ── FORM HEADER ────────────────────────────────────────── */
    /* ── FORM CORE ──────────────────────────────────────────── */
    /* ── FORM ELEMENTS ──────────────────────────────────────── */
    /* ── FORM VALIDATION ───────────────────────────────────── */
    /* ── PASSWORD TOGGLE ────────────────────────────────────── */
    .input-password-wrap {
      position: relative;
    }

    .input-password-wrap .form-input {
      padding-right: 48px;
    }

    .password-toggle {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: #999;
      transition: color var(--t);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .password-toggle:hover { color: var(--black); }

    .toggle-icon-hide { display: none; }
    .password-toggle.is-visible .toggle-icon-show { display: none; }
    .password-toggle.is-visible .toggle-icon-hide { display: block; }

    /* ── BOTÃO FECHAR ────────────────────────────────────────── */
    .btn-close {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 80;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      color: var(--gray-600);
      cursor: pointer;
      transition: color 0.2s, background 0.2s;
      text-decoration: none;
    }
    .btn-close:hover {
      color: var(--black);
      background: rgba(0,0,0,0.05);
      border-radius: 50%;
    }
    .btn-close:active {
      transform: scale(0.98);
    }

    /* ── FORM FIELDS BLOCK ─────────────────────────────────── */
    /* ── ESTADO: SUCESSO ────────────────────────────────────── */
    .state-success { display: none; }
    .state-success.is-active { display: block; }
    .state-form.is-hidden { display: none; }

    /* ── ESTADO: TOKEN EXPIRADO ─────────────────────────────── */
    .state-expired { display: none; }
    .state-expired.is-active { display: block; }

    .status-icon {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
    }

    .status-icon--green { background: var(--green); }
    .status-icon--error { background: var(--error); }

    .status-title {
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 12px;
    }

    .status-title span { color: var(--green); }

    .status-text {
      font-size: 15px;
      color: var(--gray-600);
      line-height: 1.6;
      margin-bottom: 32px;
    }

    /* ── CTA ─────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: var(--f);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 18px 36px;
      min-height: 56px;
      border: none;
      cursor: pointer;
      border-radius: 0;
      transition: background var(--t), color var(--t), transform var(--t), border-color var(--t);
      width: 100%;
    }

    .btn-primary { background: var(--green); color: var(--white); }
    .btn-primary:hover { background: var(--black); }
    .btn-primary:active { transform: scale(0.98); }

    .btn__arrow { font-size: 1.2em; transition: transform var(--t); }
    .btn-primary:hover .btn__arrow { transform: translateX(3px); }

    /* ── LINK FOOTER ────────────────────────────────────────── */
    .form-login-link a {
      color: var(--black);
      font-weight: 700;
      text-decoration: none;
      border-bottom: 2px solid var(--green);
      padding-bottom: 1px;
      transition: color var(--t);
    }

    /* ── LOADING STATE ──────────────────────────────────────── */
    .btn--loading {
      pointer-events: none;
      position: relative;
      color: transparent;
    }

    .btn--loading::after {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-top-color: var(--white);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    /* ══════════════════════════════════════════════════════════
       RESPONSIVO
       ══════════════════════════════════════════════════════════ */

    /* Tablet */
    @media (max-width: 1024px) {
      .sidebar { width: 360px; padding: 40px; }
      .form-area { padding: 40px 48px; }
    }

    /* Mobile */
    @media (max-width: 768px) {
      .register-page { flex-direction: column; }

      .sidebar {
        width: 100%;
        padding: 24px 20px;
        min-height: auto;
        justify-content: flex-start;
        flex-direction: row;
        align-items: center;
        gap: 20px;
      }

      .sidebar__logo { margin-bottom: 0; flex-shrink: 0; max-width: 120px; }
      .sidebar__logo svg { width: 100%; height: auto; }

      .sidebar::after { display: none; }

      .form-area {
        flex: 1;
        padding: 24px 20px 40px;
        align-items: flex-start;
      }

      .form-container { max-width: 100%; }

      .form-header { margin-bottom: 12px; }
      .form-title { font-size: 22px; margin-bottom: 4px; }

      .form-fields-block { padding: 16px 16px 4px; }

      .form-input { padding: 12px 14px; font-size: 16px; }
      .input-password-wrap .form-input { padding-right: 44px; }

      .btn {
        font-size: 14px;
        padding: 16px 24px;
        min-height: 52px;
      }

      .status-title { font-size: 22px; }
      .form-login-link { font-size: 13px; }
    }

    /* Small mobile */
    @media (max-width: 380px) {
      .sidebar { padding: 20px 16px; gap: 12px; }

      .form-area { padding: 20px 16px 32px; }
      .form-fields-block { padding: 14px 12px 4px; }
    }

    /* Landscape mobile */
    @media (max-height: 500px) and (orientation: landscape) {
      .register-page { flex-direction: row; }

      .sidebar {
        width: 280px;
        padding: 24px;
        min-height: 100vh;
        min-height: 100dvh;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
      }

      .sidebar__logo { margin-bottom: 24px; }
      .sidebar__logo svg { max-width: 160px; width: 100%; height: auto; }

      .form-area { padding: 24px 32px; overflow-y: auto; }
    }

    /* Safe area */
    @supports (padding: env(safe-area-inset-top)) {
      .sidebar { padding-top: max(24px, env(safe-area-inset-top)); }
      .form-area {
        padding-bottom: max(40px, env(safe-area-inset-bottom));
        padding-left: max(20px, env(safe-area-inset-left));
        padding-right: max(20px, env(safe-area-inset-right));
      }
    }
  </style>
</head>
