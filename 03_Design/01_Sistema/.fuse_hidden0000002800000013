  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_components/btn.css" />
  <link rel="stylesheet" href="_components/modal.css" />
  <link rel="stylesheet" href="_components/sidebar.css" />
  <link rel="stylesheet" href="_components/topbar.css" />
  <link rel="stylesheet" href="_components/accordion.css" />
  <style>
    /* Hover-only: em devices touch (sem hover real), neutraliza estados hover
       que ficam "stuck" depois do tap (transform, translate). Cosmética; não toca em color/background. */

    /* ══════════════════════════════════════════════════════════
       RESET
       ══════════════════════════════════════════════════════════ */    body {
      font-family: var(--f);
      font-size: 16px;
      line-height: 1.6;
      color: var(--black);
      background: var(--off-white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    /* ══════════════════════════════════════════════════════════
       LAYOUT
       ══════════════════════════════════════════════════════════ */
    .dashboard { display: flex; min-height: 100vh; min-height: 100dvh; }

    /* ── SIDEBAR ──────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w); background: var(--white);
      border-right: 1px solid var(--gray-300);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 50;
    }
    .sidebar__header { padding: 28px 24px 32px; }
    .sidebar__logo { height: 72px; width: auto; display: block; }
    .sidebar__nav { flex: 1; padding: 0 12px; }
    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px; font-size: 13px; font-weight: 500;
      color: var(--gray-600); transition: color var(--t), background var(--t);
      margin-bottom: 2px; position: relative;
    }
    .nav-item:hover { color: var(--black); background: var(--off-white); }
    .nav-item--active { color: var(--black); font-weight: 700; background: var(--off-white); }
    .nav-item--active::before {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; background: var(--green);
    }
    .nav-item__icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.6; }
    .nav-item--active .nav-item__icon { opacity: 1; }
    .sidebar__user {
      padding: 20px 24px; border-top: 1px solid var(--gray-300);
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar__avatar {
      width: 32px; height: 32px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; letter-spacing: 0.02em;
    }
    .sidebar__user-info { flex: 1; min-width: 0; }
    .sidebar__user-name { font-size: 12px; font-weight: 700; color: var(--black); line-height: 1.2; }
    .sidebar__user-email {
      font-size: 11px; color: var(--gray-600); font-weight: 400; line-height: 1.3;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sidebar__logout { color: var(--gray-300); transition: color var(--t); }
    .sidebar__logout:hover { color: var(--error); }

    /* ── MAIN ─────────────────────────────────────────────── */
    .main { flex: 1; }

    /* ── TOP BAR ──────────────────────────────────────────── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 60;
      background: var(--white); border-bottom: 1px solid var(--gray-300);
      padding: 14px 24px; align-items: center; justify-content: space-between;
    }
    .topbar__logo { height: 48px; width: auto; }
    .topbar__avatar {
      width: 28px; height: 28px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════════════════════════════
       PAGE HEADER
       ══════════════════════════════════════════════════════════ */
    .page-title {
      font-size: clamp(22px, 5vw, 32px); font-weight: 800; line-height: 1.1;
      letter-spacing: -0.02em; margin-bottom: 6px;
    }
    .accent { color: var(--black); }
    .page-desc {
      font-size: 13px; color: var(--gray-600); font-weight: 400;
      line-height: 1.5; margin-bottom: 28px;
    }

    /* ══════════════════════════════════════════════════════════
       CONTENT GRID — left + right rail
       ══════════════════════════════════════════════════════════ */
    .help-grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .help-main { flex: 1; display: flex; flex-direction: column; gap: 16px; }
    .help-rail  { display: flex; flex-direction: column; gap: 16px; }

    /* ══════════════════════════════════════════════════════════
       CARDS (base)
       ══════════════════════════════════════════════════════════ */
    .card {
      background: var(--white);
      border: 1px solid var(--gray-300);
      padding: 28px;
    }
    .card--wa {
      background: #eaf7ec;
      border: 1px solid var(--green);
    }

    .card__title {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--black);
      margin-bottom: 20px;
    }
    .card__title--with-icon {
      display: flex; align-items: center; gap: 8px;
    }

    /* ══════════════════════════════════════════════════════════
       STEPS — Como Funciona
       ══════════════════════════════════════════════════════════ */
    .steps { display: flex; flex-direction: column; gap: 0; }

    .step {
      display: flex; gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid var(--gray-200);
    }
    .step:last-child { border-bottom: none; padding-bottom: 0; }
    .step:first-child { padding-top: 0; }

    .step__num {
      width: 28px; height: 28px; flex-shrink: 0;
      background: var(--black); color: var(--white);
      font-size: 12px; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      letter-spacing: 0;
      margin-top: 1px;
    }

    .step__body {}
    .step__title {
      font-size: 14px; font-weight: 700; color: var(--black);
      line-height: 1.3; margin-bottom: 4px;
    }
    .step__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.6;
      text-wrap: pretty;
    }

    /* ══════════════════════════════════════════════════════════
       SCREEN LIST — O que cada tela faz
       ══════════════════════════════════════════════════════════ */
    .screen-list { display: flex; flex-direction: column; gap: 0; }

    .screen-item {
      font-size: 13px; color: var(--gray-600); line-height: 1.65;
      padding: 12px 0;
      border-bottom: 1px solid var(--gray-200);
    }
    .screen-item:last-child { border-bottom: none; padding-bottom: 0; }
    .screen-item:first-child { padding-top: 0; }
    .screen-item strong { color: var(--black); font-weight: 700; }

    /* ══════════════════════════════════════════════════════════
       SEARCH BAR
       ══════════════════════════════════════════════════════════ */
    .help-search {
      position: relative;
      margin-bottom: 32px;
    }
    .help-search__input {
      width: 100%;
      padding: 14px 16px 14px 44px;
      font-family: var(--f);
      font-size: 15px;
      font-weight: 400;
      border: 1px solid var(--gray-300);
      background: var(--white);
      color: var(--black);
      transition: border-color 0.24s;
    }
    .help-search__input::placeholder { color: #999; }
    .help-search__input:focus {
      outline: none;
      border-color: var(--black);
    }
    .help-search__icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-300);
      pointer-events: none;
    }
    .help-search__empty {
      text-align: center;
      padding: 40px 20px;
      color: var(--gray-600);
      font-size: 14px;
      display: none;
    }

    /* ══════════════════════════════════════════════════════════
       FAQ ACCORDION
       ══════════════════════════════════════════════════════════ */
    .faq-item {
      border-bottom: 1px solid var(--gray-300);
    }
    .faq-item:first-child {
      border-top: 1px solid var(--gray-300);
    }
    .faq-trigger {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0;
      font-family: var(--f);
      font-size: 15px;
      font-weight: 700;
      color: var(--black);
      text-align: left;
      cursor: pointer;
      background: none;
      border: none;
    }
    .faq-trigger__chevron {
      flex-shrink: 0;
      transition: transform 0.24s;
      color: var(--gray-600);
    }
    .faq-item--open .faq-trigger__chevron {
      transform: rotate(180deg);
    }
    .faq-body {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.3s ease;
    }
    .faq-item--open .faq-body {
      grid-template-rows: 1fr;
    }
    .faq-body__inner {
      overflow: hidden;
    }
    .faq-body__content {
      padding: 0 0 18px;
      font-size: 14px;
      color: var(--gray-600);
      line-height: 1.6;
    }
    .faq-item--hidden { display: none; }

    /* ══════════════════════════════════════════════════════════
       WHATSAPP BUTTON
       ══════════════════════════════════════════════════════════ */
    .btn-wa {
      display: flex; align-items: center; justify-content: center;
      width: 100%; padding: 14px 24px;
      background: var(--wa); color: var(--white);
      font-family: var(--f); font-size: 13px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.04em;
      border: none; border-radius: 4px;
      transition: background 0.2s ease;
      margin-top: 4px;
      text-decoration: none;
      cursor: pointer;
    }
    .btn-wa:hover { background: var(--wa-hover); }
    .btn-wa:active { transform: scale(0.98); }

    /* ══════════════════════════════════════════════════════════
       SECURITY CHECKLIST
       ══════════════════════════════════════════════════════════ */
    .check-list { display: flex; flex-direction: column; gap: 10px; }
    .check-item {
      display: flex; align-items: flex-start; gap: 10px;
      font-size: 13px; color: var(--gray-600); line-height: 1.5;
    }
    .check-item__icon {
      flex-shrink: 0; margin-top: 1px;
      color: var(--green);
    }

    /* ══════════════════════════════════════════════════════════
       CALLOUT — bloco informativo destacado
       ══════════════════════════════════════════════════════════ */
    .callout {
      background: var(--off-white);
      border-left: 3px solid var(--green);
      padding: 12px 16px;
      font-size: 13px;
      color: var(--gray-600);
      line-height: 1.6;
      margin-top: 14px;
    }
    .callout strong { color: var(--black); }

    /* ══════════════════════════════════════════════════════════
       PARTNER TAG — selo de parceiro
       ══════════════════════════════════════════════════════════ */
    .partner-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gray-600);
      border: 1px solid var(--gray-300);
      padding: 5px 10px;
      margin-top: 14px;
    }

    /* ══════════════════════════════════════════════════════════
       PAYMENT HIGHLIGHT — zero adiantado
       ══════════════════════════════════════════════════════════ */
    .payment-zero {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--black);
      line-height: 1.1;
      margin-bottom: 10px;
    }
    .payment-zero span { color: var(--green); }

    /* ══════════════════════════════════════════════════════════
       WHATSAPP FAB
       ══════════════════════════════════════════════════════════ */
    .fab {
      position: fixed; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      width: 68px; height: 68px;
      background: var(--green); border: 2px solid var(--black);
      border-radius: 0; color: var(--white); box-shadow: none;
      transition: background var(--t), color var(--t), border-color var(--t);
    }
    .fab:hover { background: var(--black); border-color: var(--black); }
    .fab__icon { width: 36px; height: 36px; flex-shrink: 0; }

    /* ══════════════════════════════════════════════════════════
       MOBILE-FIRST RESPONSIVE
       ══════════════════════════════════════════════════════════ */
    .sidebar { display: none; }
    .topbar  { display: flex; }
    .main    { padding: 72px 24px 100px; max-width: 100%; }
    .page-title { font-size: 22px; }
    .fab     { bottom: max(16px, env(safe-area-inset-bottom)); right: 16px; }

    @media (min-width: 640px) {
      .main { padding: 72px 24px 100px; }
      .page-title { font-size: 26px; }
    }

    @media (min-width: 960px) {
      .sidebar { display: flex; }
      .topbar  { display: none; }
      .main    { margin-left: var(--sidebar-w); padding: 40px 40px 80px; max-width: 1100px; }
      .page-title { font-size: 28px; }
      .fab     { width: 80px; height: 80px; bottom: max(36px, env(safe-area-inset-bottom)); right: 36px; }
      .fab__icon { width: 40px; height: 40px; }
    }

    @media (min-width: 860px) {
      .help-grid { flex-direction: row; align-items: flex-start; gap: 20px; }
      .help-rail { width: 272px; flex-shrink: 0; }
    }

    @media (min-width: 1200px) {
      .main { padding: 40px 48px 80px; }
      .help-rail { width: 292px; }
    }

    @supports (padding: env(safe-area-inset-top)) {
      .topbar { padding-top: max(14px, env(safe-area-inset-top)); }
      .main   { padding-bottom: max(100px, calc(80px + env(safe-area-inset-bottom))); }
      .fab    { bottom: max(16px, calc(8px + env(safe-area-inset-bottom))); }
    }

    /* ══════════════════════════════════════════════════════════
       LOGOUT MODAL
       ══════════════════════════════════════════════════════════ */
    .logout-overlay {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .logout-overlay.is-open { opacity: 1; pointer-events: all; }

    .logout-modal {
      background: var(--white);
      border: 2px solid var(--black);
      padding: 28px 28px 24px;
      width: 100%; max-width: 360px;
    }
    .logout-modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--error);
      margin-bottom: 8px;
    }
    .logout-modal__title {
      font-size: 20px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.15; margin-bottom: 8px;
    }
    .logout-modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55;
      margin-bottom: 24px;
    }
    .logout-modal__actions {
      display: flex; gap: 10px; justify-content: flex-end;
    }
    .btn-logout-cancel {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--black); cursor: pointer;
      border: 1.5px solid var(--gray-300);
      transition: border-color var(--t), background var(--t);
    }
    .btn-logout-cancel:hover { border-color: var(--black); background: var(--off-white); }
    .btn-logout-confirm {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--error); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--error);
      transition: background var(--t), border-color var(--t);
    }    .btn-logout-cancel:active, .btn-logout-confirm:active { transform: scale(0.98); }

  </style>
</head>
<body>

