<div class="register-page">

  <!-- ── SIDEBAR ─────────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar__logo">
      <svg style="color: var(--white)" aria-label="Basta." role="img" viewBox="0 0 602.25 254.23"><use href="#logo-basta"/></svg>
    </div>

  </aside>

  <!-- ── FORM AREA ───────────────────────────────────────── -->
  <main class="form-area" id="form-cadastro">
    <div class="form-container">

      <div class="form-header">
        <h1 class="form-title">Crie Sua Conta<span style="color:var(--green)">.</span></h1>
        <p class="form-subtitle">Esse é o primeiro passo para retomar o<br class="m-break"> controle sobre sua vida financeira.</p>
      </div>

      <form novalidate onsubmit="event.preventDefault(); if(validateRegister()) simulateLoading(document.querySelector('.btn-primary'))">
        <div class="form-core">

          <!-- 1. WhatsApp (read-only — já verificado no passo anterior) -->
          <div class="form-group">
            <label class="form-label" for="whatsapp">WhatsApp</label>
            <div class="input-wrapper">
              <input type="text" id="whatsapp" class="form-input form-input--disabled" value="(19) •••••-5723" disabled style="padding-right: 120px;">
              <span class="input-badge input-badge--whatsapp">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Verificado
              </span>
            </div>
          </div>

          <!-- 2. Email + Senha — bloco de campos ativos -->
          <div class="form-fields-block">

            <!-- Email -->
            <div class="form-group">
              <label class="form-label" for="email">Email</label>
              <input type="email" id="email" class="form-input" placeholder="seu@email.com" autocomplete="email">
              <div class="form-error" id="email-error" hidden>
                <svg class="form-error__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>Informe um email válido.</span>
              </div>
            </div>

            <!-- Senha -->
            <div class="form-group">
              <label class="form-label" for="senha">Senha</label>
              <div class="password-wrapper">
                <input type="password" id="senha" class="form-input" placeholder="Mínimo de 8 caracteres" autocomplete="new-password">
                <button type="button" class="password-toggle" aria-label="Mostrar senha" onclick="togglePassword('senha', this)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
              <div class="form-error" id="senha-error" hidden>
                <svg class="form-error__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>Mínimo de 8 caracteres.</span>
              </div>
            </div>

          </div>

          <!-- Divisor -->
          <div class="form-divider">
            <span class="form-divider__text">ou continue com</span>
          </div>

          <!-- OAuths -->
          <div class="oauth-list">

            <!-- Google -->
            <button type="button" class="btn-oauth btn-oauth--google" onclick="simulateLoading(this)">
              <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Continuar com Google
            </button>

            <!-- Apple -->
            <button type="button" class="btn-oauth btn-oauth--apple" onclick="simulateLoading(this)">
              <svg width="17" height="17" viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-43.8-155.5-127.4C46 537.1 29.6 437.1 29.6 341.5c0-173 112.8-264.8 224.3-264.8 60.3 0 110.4 40.2 149.4 40.2 37 0 95.3-42.5 165.1-42.5zm-104.5-181.2c30.7-36.3 52.5-86.9 52.5-137.5 0-7.1-.6-14.3-1.9-20.1-49.3 1.9-107.9 33.1-142.4 74.2-27.5 31.3-53.8 81.9-53.8 133.2 0 7.7 1.3 15.4 1.9 17.9 3.2.6 8.4 1.3 13.6 1.3 44.5 0 100.3-29.4 130.1-68.8z"/>
              </svg>
              Continuar com Apple
            </button>

            <!-- Facebook -->
            <button type="button" class="btn-oauth btn-oauth--facebook" onclick="simulateLoading(this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
