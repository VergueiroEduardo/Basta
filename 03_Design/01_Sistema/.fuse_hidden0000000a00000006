<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Basta. — Criar Conta</title>
  <meta name="description" content="Crie sua conta na Basta e comece a negociar suas dívidas de forma justa e transparente." />
  <meta name="theme-color" content="#000000" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- BASTA FOUNDATION INJECTED -->
  <link rel="stylesheet" href="_foundation/tokens.css" />
  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_components/btn.css" />
  <link rel="stylesheet" href="_components/form.css" />
  <style>

    /* ── RESET ──────────────────────────────────────────────── */    body {
      font-family: var(--f);
      font-size: 18px;
      line-height: 1.6;
      color: var(--black);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    input { font-family: inherit; }
    :where(button, a, input, select, textarea) { border-radius: 0; -webkit-appearance: none; }

    /* ── ACESSIBILIDADE ─────────────────────────────────────── */
    .skip-link {
      position: absolute; top: -6rem; left: 24px;
      background: var(--green); color: var(--white);
      font-size: 14px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 14px 24px; z-index: 9999; transition: top var(--t);
    }
    .skip-link:focus { top: 1rem; }    /* ── LAYOUT PRINCIPAL ───────────────────────────────────── */
    .register-page {
      display: flex;
      min-height: 100vh;
      min-height: 100dvh;
    }

    /* ── SIDEBAR ────────────────────────────────────────────── */
    .sidebar {
      width: 440px;
      background: var(--black);
      color: var(--white);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 48px;
      flex-shrink: 0;
      position: relative;
      overflow: hidden;
    }

    .sidebar__logo { margin-bottom: 48px; }

    .sidebar__headline {
      font-size: clamp(32px, 3.5vw, 48px);
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .sidebar__headline-accent { color: var(--green); }

    .sidebar__subtext {
      font-size: 15px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.6;
      max-width: 300px;
    }

    .sidebar::after { display: none; }

    /* ── FORM AREA ──────────────────────────────────────────── */
    /* ── FORM HEADER ────────────────────────────────────────── */
    /* ── FORM CORE — WhatsApp + bloco + CTA como unidade ───── */
    /* ── FORM ELEMENTS ──────────────────────────────────────── */
    .form-input--disabled {
      background: var(--off-white);
      color: var(--gray-600);
      cursor: not-allowed;
      border-color: var(--gray-300);
    }
    .form-input--disabled:focus { border-color: var(--gray-300); box-shadow: none; }

    .form-input--readonly {
      background: #F5F5F5;
      color: var(--gray-600);
      cursor: not-allowed;
    }

    /* ── FORM VALIDATION ───────────────────────────────────── */
    /* ── FORM FIELDS BLOCK ─────────────────────────────────── */    .form-fields-block .form-row { margin-bottom: 0; }

    /* ── FORM ROWS ──────────────────────────────────────────── */
    .form-row {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .form-row .form-group { flex: 1; }
    .form-row .form-group--fixed { flex: 0 0 170px; }

    /* ── DIVIDER ────────────────────────────────────────────── */
    .form-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 24px 0;
    }

    .form-divider::before,
    .form-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--gray-200, #E5E5E5);
    }

    .form-divider__text {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
      white-space: nowrap;
    }

    /* ── OAUTH BUTTONS ──────────────────────────────────────── */
    .oauth-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .btn-oauth {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--f);
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.01em;
      padding: 14px 20px;
      min-height: 50px;
      width: 100%;
      background: var(--white);
      color: var(--black);
      border: 1.5px solid #D0D0D0;
      cursor: pointer;
      transition: border-color var(--t), background var(--t), transform var(--t);
      border-radius: 0;
      text-decoration: none;
    }

    .btn-oauth:hover {
      border-color: var(--black);
      background: #FAFAFA;
    }

    .btn-oauth:active { transform: scale(0.99); }

    .btn-oauth--apple {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }

    .btn-oauth--apple:hover {
      background: #222;
      border-color: #222;
    }

    /* ── WHATSAPP BADGE ─────────────────────────────────────── */
    .input-wrapper { position: relative; }

    .input-badge {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }

    .input-badge--whatsapp { color: var(--wa); }

    /* ── PASSWORD TOGGLE ────────────────────────────────────── */
    .password-wrapper { position: relative; }
    .password-wrapper .form-input { padding-right: 48px; }

    .password-toggle {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      cursor: pointer;
      color: #999;
      transition: color var(--t);
      padding: 0;
    }

    .password-toggle:hover { color: var(--black); }

    /* ── BOTÃO FECHAR ────────────────────────────────────────── */
    .btn-close {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 80;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      color: var(--gray-600);
      cursor: pointer;
      transition: color 0.2s, background 0.2s;
      text-decoration: none;
    }
    .btn-close:hover {
      color: var(--black);
      background: rgba(0,0,0,0.05);
      border-radius: 50%;
    }
    .btn-close:active {
      transform: scale(0.98);
    }

    /* ── CTA ─────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: var(--f);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 18px 36px;
      min-height: 56px;
      border: none;
      cursor: pointer;
      border-radius: 0;
      transition: background var(--t), color var(--t), transform var(--t), border-color var(--t);
      width: 100%;
    }

    .btn-primary { background: var(--green); color: var(--white); }
    .btn-primary:hover { background: var(--black); }
    .btn-primary:active { transform: scale(0.98); }
    .btn-primary:disabled { background: var(--gray-300); color: #999; cursor: not-allowed; }

    .btn__arrow { font-size: 1.2em; transition: transform var(--t); }
    .btn-primary:hover .btn__arrow { transform: translateX(3px); }

    /* ── TERMS & LOGIN LINK ─────────────────────────────────── */
    .form-terms {
      font-size: 12px;
      color: #999;
      margin-top: 16px;
      text-align: center;
      line-height: 1.5;
    }

    .form-terms a {
      color: var(--black);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .form-terms a:hover { color: var(--green); }

    .form-login-link a {
      color: var(--black);
      font-weight: 700;
      text-decoration: none;
      border-bottom: 2px solid var(--green);
      padding-bottom: 1px;
      transition: border-color var(--t), color var(--t);
    }

    /* ── LOADING STATE ──────────────────────────────────────── */    .btn--loading {
      pointer-events: none;
      opacity: 0.7;
      position: relative;
    }
    .btn--loading .btn__text { visibility: hidden; }
    .btn--loading::after {
      content: '';
      position: absolute;
      width: 18px;
      height: 18px;
      top: 50%;
      left: 50%;
      margin: -9px 0 0 -9px;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: var(--white);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    /* ══════════════════════════════════════════════════════════
       RESPONSIVO
       ══════════════════════════════════════════════════════════ */

    /* Tablet */
    @media (max-width: 1024px) {
      .sidebar { width: 360px; padding: 40px; }
      .form-area { padding: 40px 48px; }
    }

    /* Mobile — sidebar vira header compacto */
    @media (max-width: 768px) {
      .register-page { flex-direction: column; }

      .sidebar {
        width: 100%;
        padding: 24px 20px;
        min-height: auto;
        justify-content: flex-start;
        flex-direction: row;
        align-items: center;
        gap: 20px;
      }

      .sidebar__logo { margin-bottom: 0; flex-shrink: 0; max-width: 120px; }
      .sidebar__logo svg { width: 100%; height: auto; }

      .sidebar__text-group { flex: 1; min-width: 0; }

      .sidebar__headline {
        font-size: 18px;
        margin-bottom: 4px;
        white-space: normal;
        line-height: 1.2;
      }

      .sidebar__br { display: none; }

      .sidebar__subtext {
        font-size: 12px;
        max-width: 100%;
        line-height: 1.4;
        white-space: normal;
        word-break: break-word;
      }

      br.m-break { display: inline; }
      @media (min-width: 768px) { br.m-break { display: none; } }

      .sidebar::after { display: none; }

      .form-area {
        flex: 1;
        padding: 24px 20px 40px;
        align-items: flex-start;
      }

      .form-container { max-width: 100%; }

      .form-header { margin-bottom: 12px; }
      .form-title { font-size: 22px; margin-bottom: 4px; }

      .form-fields-block { padding: 16px 16px 4px; }

      .form-input { padding: 12px 14px; font-size: 16px; } /* 16px previne zoom iOS */

      .form-row {
        flex-direction: column;
        gap: 0;
      }

      .form-row .form-group--fixed { flex: 1; }

      .cep-row { flex-wrap: wrap; }
      .cep-row__cep { flex: 1 1 100%; }
      .cep-row__cidade { flex: 1; }
      .cep-row__uf { flex: 0 0 72px; }

      .btn {
        font-size: 14px;
        padding: 16px 24px;
        min-height: 52px;
      }

      .form-terms { font-size: 11px; }
      .form-login-link { font-size: 13px; }
    }

    /* Small mobile (iPhone SE, etc.) */
    @media (max-width: 380px) {
      .sidebar { padding: 20px 16px; gap: 12px; }
      .sidebar__headline { font-size: 16px; }
      .sidebar__subtext { font-size: 11px; }

      .form-area { padding: 20px 16px 32px; }
      .form-fields-block { padding: 14px 12px 4px; }
      .form-row { gap: 0; }
      .cep-row { gap: 8px; }
    }

    /* Landscape mobile — sidebar como faixa lateral fina */
    @media (max-height: 500px) and (orientation: landscape) {
      .register-page { flex-direction: row; }

      .sidebar {
        width: 280px;
        padding: 24px;
        min-height: 100vh;
        min-height: 100dvh;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
      }

      .sidebar__logo { margin-bottom: 24px; max-width: 160px; }
      .sidebar__logo svg { width: 100%; height: auto; }
      .sidebar__headline { font-size: 24px; }

      .form-area {
        padding: 24px 32px;
        overflow-y: auto;
      }
    }

    /* Safe area para notch/dynamic island */
    @supports (padding: env(safe-area-inset-top)) {
      .sidebar { padding-top: max(24px, env(safe-area-inset-top)); }
      .form-area {
        padding-bottom: max(40px, env(safe-area-inset-bottom));
        padding-left: max(20px, env(safe-area-inset-left));
        padding-right: max(20px, env(safe-area-inset-right));
      }
    }
  </style>
</head>
