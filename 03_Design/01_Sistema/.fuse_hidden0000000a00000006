              <span class="btn__text">Criar Conta <span class="btn__arrow">&rarr;</span></span>
            </button>
          </div>

        </div>

        <p class="form-terms">
          Ao criar sua conta, você concorda com os <a href="#">Termos de Uso</a> e a <a href="#">Política de Privacidade</a>.
        </p>

        <p class="form-login-link">
          Já tem uma conta? <a href="03_basta-login.html">Entrar</a>
        </p>
      </form>

    </div>
  </main>

</div>

<script>
  /* ── FORM VALIDATION ────────────────────────────────────── */
  function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function validateField(fieldId, isValid, errorMsg = '') {
    const field = document.getElementById(fieldId);
    const errorEl = document.getElementById(fieldId + '-error');

    if (!isValid) {
      field.classList.add('form-input--error');
      if (errorEl) {
        errorEl.removeAttribute('hidden');
        if (errorMsg) errorEl.querySelector('span').textContent = errorMsg;
      }
      return false;
    } else {
      field.classList.remove('form-input--error');
      if (errorEl) errorEl.setAttribute('hidden', '');
      return true;
    }
  }

  function validateRegister() {
    const email = document.getElementById('email').value.trim();
    const senha = document.getElementById('senha').value;

    let isValid = true;
    isValid = validateField('email', email && validateEmail(email), 'Informe um email válido.') && isValid;
    isValid = validateField('senha', senha.length >= 8, 'Mínimo de 8 caracteres.') && isValid;
    return isValid;
  }

  // Validação no blur de cada campo
  document.getElementById('email')?.addEventListener('blur', function() {
    if (this.value.trim()) {
      validateField('email', validateEmail(this.value.trim()), 'Informe um email válido.');
    }
  });

  document.getElementById('senha')?.addEventListener('blur', function() {
    if (this.value) {
      validateField('senha', this.value.length >= 8, 'Mínimo de 8 caracteres.');
    }
  });

  /* ── LOADING STATE ──────────────────────────────────────── */
  function simulateLoading(btn) {
    btn.classList.add('btn--loading');
    btn.setAttribute('aria-disabled', 'true');
    setTimeout(function() {
      btn.classList.remove('btn--loading');
      btn.setAttribute('aria-disabled', 'false');
    }, 2000);
  }

  /* ── TOGGLE PASSWORD ────────────────────────────────────── */
  function togglePassword(inputId, btn) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
      input.type = 'text';
      btn.setAttribute('aria-label', 'Ocultar senha');
      btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    } else {
      input.type = 'password';
      btn.setAttribute('aria-label', 'Mostrar senha');
      btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    }
  }
</script>

