<script>
  /* ── Filter pills (Todos / Usuários / Admins / etc.) ─────── */
  function togglePill(pill) {
    document.querySelectorAll('.filter-pill').forEach(function(p){ p.classList.remove('filter-pill--active'); });
    pill.classList.add('filter-pill--active');
  }

  /* ── Bulk selection ───────────────────────────────────────── */
  function rowCheck(input) {
    var row = input.closest('tr');
    if (input.checked) row.classList.add('is-selected');
    else row.classList.remove('is-selected');
    updateBulkBar();
  }
  function toggleAll(input) {
    document.querySelectorAll('.row-check__input').forEach(function(c){
      c.checked = input.checked;
      var r = c.closest('tr');
      if (input.checked) r.classList.add('is-selected');
      else r.classList.remove('is-selected');
    });
    updateBulkBar();
  }
  function updateBulkBar() {
    var n = document.querySelectorAll('.row-check__input:checked').length;
    var bar = document.getElementById('bulkBar');
    var count = document.getElementById('bulkCount');
    if (n > 0) {
      bar.classList.add('is-active');
      count.textContent = n + (n === 1 ? ' selecionado' : ' selecionados');
    } else {
      bar.classList.remove('is-active');
    }
  }

  /* ── Kebab dropdowns ──────────────────────────────────────── */
  function toggleKebab(btn, e) {
    if (e) e.stopPropagation();
    var menu = btn.nextElementSibling;
    var isOpen = menu.classList.contains('is-open');
    document.querySelectorAll('.kebab__menu').forEach(function(m){ m.classList.remove('is-open'); });
    if (!isOpen) menu.classList.add('is-open');
  }
  document.addEventListener('click', function(){
    document.querySelectorAll('.kebab__menu').forEach(function(m){ m.classList.remove('is-open'); });
  });

  /* ── User detail drawer ──────────────────────────────────── */
  function openDrawer(name, email, role) {
    var av = document.getElementById('drawerAvatar');
    av.firstChild.textContent = (name.split(' ').map(function(s){return s[0];}).join('').slice(0,2).toUpperCase()) + ' ';
    av.classList.toggle('drawer__avatar--admin', role === 'admin');
    document.getElementById('drawerName').textContent = name;
    document.getElementById('drawerEmail').textContent = email;
    document.getElementById('drawerOverlay').classList.add('is-open');
    document.getElementById('drawer').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    document.getElementById('drawerOverlay').classList.remove('is-open');
    document.getElementById('drawer').classList.remove('is-open');
    document.body.style.overflow = '';
  }

  /* ── Invite modal ─────────────────────────────────────────── */
  function openInvite() {
    document.getElementById('inviteModal').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeInvite() {
    document.getElementById('inviteModal').classList.remove('is-open');
    document.body.style.overflow = '';
  }
  document.getElementById('inviteModal').addEventListener('click', function(e){
    if (e.target === this) closeInvite();
  });

  function selectRole(el) {
    document.querySelectorAll('.role-opt').forEach(function(r){ r.classList.remove('role-opt--active'); });
    el.classList.add('role-opt--active');
  }

  /* ── Delete modal ─────────────────────────────────────────── */
  function openDelete(name) {
    document.getElementById('deleteName').textContent = name;
    document.getElementById('deleteModal').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeDelete() {
    document.getElementById('deleteModal').classList.remove('is-open');
    document.body.style.overflow = '';
  }
  document.getElementById('deleteModal').addEventListener('click', function(e){
    if (e.target === this) closeDelete();
  });

  /* ── Logout ───────────────────────────────────────────────── */
  let lastFocusedElement = null;
  function openLogout() {
    lastFocusedElement = document.activeElement;
    document.getElementById('logoutModal').classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.getElementById('logoutCancel').focus();
  }
  function closeLogout() {
    document.getElementById('logoutModal').classList.remove('is-open');
    document.body.style.overflow = '';
    if (lastFocusedElement) lastFocusedElement.focus();
  }
  document.getElementById('logoutModal').addEventListener('click', function(e){ if (e.target === this) closeLogout(); });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') {
      if (document.getElementById('drawer').classList.contains('is-open')) closeDrawer();
      if (document.getElementById('inviteModal').classList.contains('is-open')) closeInvite();
      if (document.getElementById('deleteModal').classList.contains('is-open')) closeDelete();
      if (document.getElementById('logoutModal').classList.contains('is-open')) closeLogout();
      document.querySelectorAll('.kebab__menu').forEach(function(m){ m.classList.remove('is-open'); });
    }
  });
</script>

</body>
</html>
