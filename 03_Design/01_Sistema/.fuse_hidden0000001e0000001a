<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Basta. — Usuários</title>
  <meta name="theme-color" content="#000000" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- BASTA FOUNDATION INJECTED -->
  <link rel="stylesheet" href="_foundation/tokens.css" />
  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_components/btn.css" />
  <link rel="stylesheet" href="_components/modal.css" />
  <link rel="stylesheet" href="_components/sidebar.css" />
  <link rel="stylesheet" href="_components/topbar.css" />
  <link rel="stylesheet" href="_components/badge.css" />
  <style>
    /* RESET LOCAL */    body {
      font-family: var(--f);
      font-size: 16px;
      line-height: 1.6;
      color: var(--black);
      background: var(--off-white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    /* LAYOUT */
    .dashboard { display: flex; min-height: 100vh; min-height: 100dvh; }

    .sidebar {
      width: var(--sidebar-w); background: var(--white);
      border-right: 1px solid var(--gray-300);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 50;
      overflow-y: auto;
    }
    .sidebar__header { padding: 28px 24px 32px; }
    .sidebar__logo { height: 72px; width: auto; display: block; }
    .sidebar__nav { flex: 1; padding: 0 12px; }
    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px; font-size: 13px; font-weight: 500;
      color: var(--gray-600); transition: color var(--t), background var(--t);
      margin-bottom: 2px; position: relative;
    }
    .nav-item:hover { color: var(--black); background: var(--off-white); }
    .nav-item--active { color: var(--black); font-weight: 700; background: var(--off-white); }
    .nav-item--active::before {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; background: var(--green);
    }
    .nav-item__icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.6; }
    .nav-item--active .nav-item__icon { opacity: 1; }
    .sidebar__section-title {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.14em; color: var(--gray-600);
      padding: 24px 16px 8px; margin-top: 12px;
      border-top: 1px solid var(--gray-200);
    }
    .sidebar__user {
      padding: 20px 24px; border-top: 1px solid var(--gray-300);
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar__avatar {
      width: 32px; height: 32px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; letter-spacing: 0.02em;
    }
    .sidebar__user-info { flex: 1; min-width: 0; }
    .sidebar__user-name { font-size: 12px; font-weight: 700; color: var(--black); line-height: 1.2; }
    .sidebar__user-email {
      font-size: 11px; color: var(--gray-600); font-weight: 400; line-height: 1.3;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sidebar__logout { color: var(--gray-300); transition: color var(--t); }
    .sidebar__logout:hover { color: var(--error); }

    .main { flex: 1; }
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 60;
      background: var(--white); border-bottom: 1px solid var(--gray-300);
      padding: 14px 24px; align-items: center; justify-content: space-between;
    }
    .topbar__logo { height: 48px; width: auto; }
    .topbar__avatar {
      width: 28px; height: 28px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; letter-spacing: 0.02em;
    }

    /* PAGE HEADER */
    .page-head {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 16px; margin-bottom: 24px; flex-wrap: wrap;
    }
    .page-title {
      font-size: clamp(22px, 5vw, 32px); font-weight: 800; line-height: 1.1;
      letter-spacing: -0.02em; margin-bottom: 6px;
    }
    .page-title .accent { color: var(--black); }
    .page-desc {
      font-size: 13px; color: var(--gray-600); font-weight: 400; line-height: 1.5;
    }
    .btn-add {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 16px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--black); color: var(--white);
      border: 1.5px solid var(--black);
      transition: background var(--t), border-color var(--t);
      cursor: pointer; flex-shrink: 0;
    }
    .btn-add:hover { background: var(--green); border-color: var(--green); }
    .btn-add svg { width: 12px; height: 12px; }

    /* ══════════════════════════════════════════════════════════
       KPI STRIP
       ══════════════════════════════════════════════════════════ */
    .kpis {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    @media (min-width: 720px) { .kpis { grid-template-columns: repeat(4, 1fr); } }
    .kpi {
      background: var(--white); border: 1px solid var(--gray-300);
      padding: 16px;
    }
    .kpi__label {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-600);
    }
    .kpi__value {
      font-size: 28px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.05; margin: 4px 0 4px;
      color: var(--black); font-variant-numeric: tabular-nums;
    }
    .kpi__delta {
      font-size: 11px; font-weight: 700;
      display: inline-flex; align-items: center; gap: 4px;
    }
    .kpi__delta--up { color: var(--green); }
    .kpi__delta--down { color: var(--error); }
    .kpi__delta--flat { color: var(--gray-600); }

    /* ══════════════════════════════════════════════════════════
       FILTERS
       ══════════════════════════════════════════════════════════ */
    .filters {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 16px; flex-wrap: wrap;
    }
    .filter-search {
      position: relative; flex: 1; min-width: 220px;
    }
    .filter-search__input {
      width: 100%; padding: 11px 12px 11px 38px;
      font-family: var(--f); font-size: 13px;
      border: 1px solid var(--gray-300); background: var(--white);
      transition: border-color var(--t);
    }
    .filter-search__input:focus { outline: none; border-color: var(--black); }
    .filter-search__icon {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      color: var(--gray-300); pointer-events: none;
    }
    .filter-pill {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 14px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--gray-600);
      border: 1.5px solid var(--gray-300);
      transition: all var(--t); cursor: pointer; white-space: nowrap;
    }
    .filter-pill:hover { color: var(--black); border-color: var(--black); }
    .filter-pill--active {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .filter-pill__count {
      display: inline-block;
      font-size: 10px; font-weight: 800;
      padding: 1px 6px;
      background: var(--gray-200); color: var(--gray-600);
    }
    .filter-pill--active .filter-pill__count {
      background: rgba(255,255,255,0.18); color: var(--white);
    }

    .filter-select {
      position: relative;
    }
    .filter-select__btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 12px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--black);
      border: 1.5px solid var(--gray-300);
      cursor: pointer; transition: border-color var(--t);
    }
    .filter-select__btn:hover { border-color: var(--black); }
    .filter-select__btn svg { width: 11px; height: 11px; opacity: 0.6; }

    /* ══════════════════════════════════════════════════════════
       BULK BAR (visible when selection > 0)
       ══════════════════════════════════════════════════════════ */
    .bulk-bar {
      display: none;
      align-items: center; justify-content: space-between;
      gap: 12px; flex-wrap: wrap;
      padding: 12px 18px;
      background: var(--black); color: var(--white);
      margin-bottom: 16px;
    }
    .bulk-bar.is-active { display: flex; }
    .bulk-bar__count {
      font-size: 12px; font-weight: 800;
      letter-spacing: 0.04em;
    }
    .bulk-bar__actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .bulk-btn {
      padding: 8px 14px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--white);
      border: 1.5px solid rgba(255,255,255,0.3);
      cursor: pointer; transition: all var(--t);
      display: inline-flex; align-items: center; gap: 6px;
    }
    .bulk-btn:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }
    .bulk-btn--danger { color: #FCA5A5; border-color: #FCA5A5; }
    .bulk-btn--danger:hover { background: rgba(220,38,38,0.18); border-color: #FCA5A5; }
    .bulk-btn svg { width: 12px; height: 12px; }

    /* ══════════════════════════════════════════════════════════
       TABLE
       ══════════════════════════════════════════════════════════ */
    .table-wrap {
      background: var(--white);
      border: 1px solid var(--gray-300);
      overflow: hidden;
    }
    .table-scroll {
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .table {
      width: 100%;
      border-collapse: collapse;
      min-width: 980px;
    }
    .table thead th {
      font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--gray-600);
      text-align: left;
      padding: 14px 16px;
      background: var(--off-white);
      border-bottom: 1px solid var(--gray-300);
      white-space: nowrap;
      vertical-align: middle;
    }
    .table thead th.is-sortable { cursor: pointer; user-select: none; }
    .table thead th.is-sortable:hover { color: var(--black); }
    .table thead th.is-sortable svg {
      width: 10px; height: 10px; vertical-align: -1px;
      margin-left: 3px; opacity: 0.5;
    }
    .table thead th.col--check { width: 36px; padding-right: 0; }
    .table thead th.col--actions { width: 40px; }

    .table tbody tr {
      border-bottom: 1px solid var(--gray-200);
      transition: background var(--t);
    }
    .table tbody tr:last-child { border-bottom: none; }
    .table tbody tr:hover { background: var(--off-white); }
    .table tbody tr.is-selected {
      background: rgba(66,180,73,0.06);
      box-shadow: inset 3px 0 0 var(--green);
    }
    .table tbody td {
      padding: 14px 16px;
      font-size: 13px;
      color: var(--black);
      vertical-align: middle;
    }

    /* ROW: checkbox */
    .row-check { width: 36px; padding-right: 0; }
    .check {
      appearance: none;
      width: 16px; height: 16px;
      border: 1.5px solid var(--gray-300);
      background: var(--white);
      cursor: pointer;
      position: relative;
      transition: border-color var(--t), background var(--t);
      vertical-align: middle;
    }
    .check:hover { border-color: var(--black); }
    .check:checked {
      background: var(--black); border-color: var(--black);
    }
    .check:checked::after {
      content: '';
      position: absolute; left: 4px; top: 1px;
      width: 5px; height: 9px;
      border: solid var(--white);
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }

    /* ROW: user cell */
    .user-cell {
      display: flex; align-items: center; gap: 12px;
      min-width: 220px;
    }
    .user-cell__avatar {
      position: relative;
      width: 36px; height: 36px;
      background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; letter-spacing: 0.02em;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .user-cell__avatar--admin { background: var(--black); }
    .user-cell__avatar--ghost { background: var(--gray-300); color: var(--gray-600); }
    .user-cell__status {
      position: absolute; bottom: -2px; right: -2px;
      width: 10px; height: 10px;
      border: 2px solid var(--white);
      border-radius: 50%;
      background: var(--gray-300);
    }
    .user-cell__status--active { background: var(--green); }
    .user-cell__status--inactive { background: var(--gray-300); }
    .user-cell__status--blocked { background: var(--error); }

    .user-cell__body { min-width: 0; }
    .user-cell__name {
      font-size: 13px; font-weight: 700; color: var(--black);
      line-height: 1.25;
    }
    .user-cell__name-empty { color: var(--gray-600); font-style: italic; font-weight: 500; }
    .user-cell__id {
      font-size: 10px; color: var(--gray-600); font-weight: 600;
      margin-top: 2px;
      font-variant-numeric: tabular-nums;
    }

    /* ROW: contact cell */
    .contact {
      display: flex; flex-direction: column; gap: 2px;
      min-width: 200px;
    }
    .contact__email {
      font-size: 12px; color: var(--black); font-weight: 500;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      max-width: 220px;
    }
    .contact__cpf {
      font-size: 11px; color: var(--gray-600); font-weight: 600;
      font-variant-numeric: tabular-nums;
    }

    /* Stage chip */
    .stage-chip {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 8px 4px 4px;
      font-size: 11px; font-weight: 700;
      color: var(--black);
      background: var(--off-white);
      border: 1px solid var(--gray-300);
      transition: border-color var(--t);
      max-width: 100%;
    }
    .stage-chip:hover { border-color: var(--black); }
    .stage-chip__num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 18px; height: 18px;
      font-size: 9px; font-weight: 800;
      background: var(--white); border: 1px solid var(--gray-300);
      color: var(--black);
      letter-spacing: 0;
    }
    .stage-chip__name {
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .stage-chip--done .stage-chip__num { background: var(--green); border-color: var(--green); color: var(--white); }
    .stage-chip--blocked { color: var(--gray-600); background: var(--gray-100); }

    /* Time / dates */
    .time {
      font-size: 12px; color: var(--gray-600); font-weight: 500;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .time strong { color: var(--black); font-weight: 700; }

    /* Role pill (clickable to change) */
    .role-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px;
      font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      border: 1.5px solid var(--gray-300);
      background: var(--white); color: var(--gray-600);
      cursor: pointer; transition: all var(--t);
      white-space: nowrap;
    }
    .role-pill:hover { border-color: var(--black); color: var(--black); }
    .role-pill--admin {
      color: var(--green); border-color: var(--green);
    }
    .role-pill--admin:hover { background: var(--green); color: var(--white); border-color: var(--green); }
    .role-pill--invited {
      color: var(--warning); border-color: var(--warning);
    }
    .role-pill--blocked {
      color: var(--error); border-color: var(--error);
    }
    .role-pill svg { width: 9px; height: 9px; opacity: 0.6; }

    /* Kebab menu */
    .kebab {
      position: relative;
    }
    .kebab__btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px;
      background: transparent; border: 1px solid transparent;
      color: var(--gray-600); cursor: pointer;
      transition: all var(--t);
    }
    .kebab__btn:hover { border-color: var(--gray-300); color: var(--black); background: var(--white); }
    .kebab__btn svg { width: 16px; height: 16px; }
    .kebab__menu {
      position: absolute; top: calc(100% + 4px); right: 0;
      background: var(--white); border: 1.5px solid var(--black);
      min-width: 180px;
      box-shadow: 0 8px 24px rgba(26,26,26,0.18);
      z-index: 20;
      display: none;
    }
    .kebab__menu.is-open { display: block; }
    .kebab__item {
      display: flex; align-items: center; gap: 10px;
      width: 100%; padding: 10px 14px;
      font-family: var(--f); font-size: 12px; font-weight: 600;
      color: var(--black);
      background: transparent; border: none; cursor: pointer;
      text-align: left;
      transition: background var(--t);
    }
    .kebab__item:hover { background: var(--off-white); }
    .kebab__item--danger { color: var(--error); }
    .kebab__item--danger:hover { background: rgba(220,38,38,0.06); }
    .kebab__item svg { width: 13px; height: 13px; flex-shrink: 0; }
    .kebab__sep {
      height: 1px; background: var(--gray-200); margin: 4px 0;
    }

    /* Pagination */
    .pagination {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px; padding: 14px 16px;
      border-top: 1px solid var(--gray-300);
      font-size: 12px; color: var(--gray-600);
      flex-wrap: wrap;
    }
    .pagination__nav { display: flex; gap: 4px; }
    .pagination__btn {
      padding: 6px 10px;
      font-family: var(--f); font-size: 11px; font-weight: 700;
      background: var(--white); color: var(--black);
      border: 1px solid var(--gray-300);
      cursor: pointer; transition: all var(--t);
      min-width: 32px;
    }
    .pagination__btn:hover { border-color: var(--black); }
    .pagination__btn--active {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .pagination__btn:disabled {
      opacity: 0.4; cursor: not-allowed;
    }

    /* ══════════════════════════════════════════════════════════
       USER DETAIL DRAWER
       ══════════════════════════════════════════════════════════ */
    .drawer-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(26,26,26,0.55);
      opacity: 0; pointer-events: none;
      transition: opacity 0.24s var(--ease);
    }
    .drawer-overlay.is-open { opacity: 1; pointer-events: all; }

    .drawer {
      position: fixed; top: 0; right: 0; bottom: 0;
      width: 100%; max-width: 720px;
      background: var(--white);
      border-left: 2px solid var(--black);
      z-index: 210;
      display: flex; flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.32s var(--ease);
    }
    .drawer.is-open { transform: translateX(0); }

    .drawer__head {
      padding: 20px 24px;
      border-bottom: 1px solid var(--gray-300);
      display: flex; align-items: center; gap: 14px;
    }
    .drawer__avatar {
      position: relative;
      width: 56px; height: 56px;
      background: var(--green); color: var(--white);
      font-size: 16px; font-weight: 800; letter-spacing: 0.02em;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .drawer__avatar--admin { background: var(--black); }
    .drawer__avatar-status {
      position: absolute; bottom: -2px; right: -2px;
      width: 14px; height: 14px;
      border: 2px solid var(--white);
      border-radius: 50%;
      background: var(--green);
    }
    .drawer__head-info { flex: 1; min-width: 0; }
    .drawer__name {
      font-size: 18px; font-weight: 800;
      letter-spacing: -0.01em; color: var(--black);
      line-height: 1.2;
    }
    .drawer__email {
      font-size: 12px; color: var(--gray-600); font-weight: 500;
      margin-top: 4px;
    }
    .drawer__close {
      width: 36px; height: 36px;
      display: inline-flex; align-items: center; justify-content: center;
      background: transparent; border: 1px solid var(--gray-300);
      color: var(--gray-600); cursor: pointer; transition: all var(--t);
    }
    .drawer__close:hover { border-color: var(--black); color: var(--black); }
    .drawer__close svg { width: 14px; height: 14px; }

    .drawer__body {
      flex: 1; overflow-y: auto;
      padding: 24px;
    }

    .field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 28px;
    }
    .field {
      padding: 12px 14px;
      background: var(--off-white);
      border-left: 3px solid var(--gray-300);
    }
    .field__label {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-600);
      margin-bottom: 4px;
    }
    .field__value {
      font-size: 13px; font-weight: 700; color: var(--black);
      font-variant-numeric: tabular-nums;
      word-break: break-word;
    }
    .field--accent { border-left-color: var(--green); }

    .section-title {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--black);
      margin: 24px 0 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--gray-300);
    }

    .quick-actions {
      display: flex; gap: 8px; flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .quick-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 14px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--black);
      border: 1.5px solid var(--gray-300);
      cursor: pointer; transition: all var(--t);
    }
    .quick-btn:hover { border-color: var(--black); }
    .quick-btn--primary {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .quick-btn--primary:hover { background: var(--green); border-color: var(--green); }
    .quick-btn--danger { color: var(--error); border-color: var(--error); }
    .quick-btn--danger:hover { background: var(--error); color: var(--white); }
    .quick-btn svg { width: 12px; height: 12px; }

    /* Audit log */
    .audit { display: flex; flex-direction: column; gap: 0; }
    .audit__item {
      display: grid;
      grid-template-columns: 16px 1fr;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid var(--gray-200);
    }
    .audit__item:last-child { border-bottom: none; }
    .audit__dot {
      width: 8px; height: 8px; background: var(--gray-300);
      border-radius: 50%;
      margin-top: 6px; margin-left: 4px;
    }
    .audit__dot--login { background: var(--green); }
    .audit__dot--admin { background: var(--blue); }
    .audit__dot--warn { background: var(--warning); }
    .audit__action {
      font-size: 12px; font-weight: 700; color: var(--black);
      line-height: 1.4;
    }
    .audit__action span { font-weight: 500; color: var(--gray-600); }
    .audit__time {
      font-size: 11px; color: var(--gray-600); font-weight: 500;
      margin-top: 2px;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 24px;
    }
    .summary {
      padding: 12px;
      background: var(--white); border: 1px solid var(--gray-300);
      text-align: center;
    }
    .summary__value {
      font-size: 22px; font-weight: 800; line-height: 1.05;
      letter-spacing: -0.02em; color: var(--black);
      font-variant-numeric: tabular-nums;
    }
    .summary__label {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--gray-600);
      margin-top: 4px;
    }

    /* ══════════════════════════════════════════════════════════
       INVITE MODAL
       ══════════════════════════════════════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .modal-overlay.is-open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--white); border: 2px solid var(--black);
      padding: 28px; width: 100%; max-width: 480px;
      max-height: 90vh; overflow-y: auto;
    }
    .modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--green);
      margin-bottom: 8px;
    }
    .modal__title {
      font-size: 20px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.15; margin-bottom: 8px;
    }
    .modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55;
      margin-bottom: 22px;
    }
    .form-field {
      margin-bottom: 16px;
    }
    .form-label {
      display: block;
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-600);
      margin-bottom: 6px;
    }
    .form-input, .form-textarea, .form-select {
      width: 100%;
      padding: 11px 14px;
      font-family: var(--f); font-size: 13px;
      border: 1px solid var(--gray-300); background: var(--white);
      transition: border-color var(--t);
      color: var(--black);
    }
    .form-input:focus, .form-textarea:focus, .form-select:focus {
      outline: none; border-color: var(--black);
    }
    .form-textarea { resize: vertical; min-height: 80px; line-height: 1.5; }

    .role-options {
      display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    }
    .role-opt {
      padding: 12px;
      border: 1.5px solid var(--gray-300);
      background: var(--white); cursor: pointer;
      transition: border-color var(--t), background var(--t);
      text-align: left;
    }
    .role-opt:hover { border-color: var(--black); }
    .role-opt--active {
      border-color: var(--green); background: rgba(66,180,73,0.05);
    }
    .role-opt__name {
      font-size: 13px; font-weight: 800; color: var(--black);
      letter-spacing: -0.01em; margin-bottom: 2px;
    }
    .role-opt__desc {
      font-size: 11px; color: var(--gray-600); line-height: 1.4;
    }
    .modal__actions {
      display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px;
    }
    .btn-cancel {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--black); cursor: pointer;
      border: 1.5px solid var(--gray-300);
    }
    .btn-cancel:hover { border-color: var(--black); background: var(--off-white); }
    .btn-primary {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--black); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--black);
      transition: background var(--t);
    }
    .btn-primary:hover { background: var(--green); border-color: var(--green); }
    .btn-danger {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--error); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--error);
    }
    .btn-danger:hover { background: #b91c1c; border-color: #b91c1c; }

    /* ══════════════════════════════════════════════════════════
       MOBILE
       ══════════════════════════════════════════════════════════ */
    .sidebar { display: none; }
    .topbar  { display: flex; }
    .main    { padding: 72px 16px 60px; max-width: 100%; }
    .page-title { font-size: 22px; }

    @media (min-width: 640px) {
      .main { padding: 72px 24px 80px; }
      .page-title { font-size: 26px; }
    }
    @media (min-width: 960px) {
      .sidebar { display: flex; }
      .topbar  { display: none; }
      .main    { margin-left: var(--sidebar-w); padding: 32px 32px 60px; max-width: 1280px; }
      .page-title { font-size: 28px; }
    }
    @media (min-width: 1280px) {
      .main { padding: 32px 40px 60px; }
    }
    @supports (padding: env(safe-area-inset-top)) {
      .topbar { padding-top: max(14px, env(safe-area-inset-top)); }
      .main   { padding-bottom: max(60px, calc(40px + env(safe-area-inset-bottom))); }
    }

    /* LOGOUT MODAL */
    .logout-overlay {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .logout-overlay.is-open { opacity: 1; pointer-events: all; }
    .logout-modal {
      background: var(--white); border: 2px solid var(--black);
      padding: 28px 28px 24px; width: 100%; max-width: 360px;
    }
    .logout-modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--error); margin-bottom: 8px;
    }
    .logout-modal__title {
      font-size: 20px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.15; margin-bottom: 8px;
    }
    .logout-modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55; margin-bottom: 24px;
    }
    .logout-modal__actions { display: flex; gap: 10px; justify-content: flex-end; }
    .btn-logout-cancel {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--black); cursor: pointer;
      border: 1.5px solid var(--gray-300);
    }
    .btn-logout-cancel:hover { border-color: var(--black); background: var(--off-white); }
    .btn-logout-confirm {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--error); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--error);
    }    /* nav-item placeholder "em breve" — sem destino ainda */
    .nav-item--soon { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
    .nav-item--soon::after {
      content: "Em breve";
      margin-left: auto;
      font-size: 9px; font-weight: 800;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--gray-600);
      border: 1px solid var(--gray-300); padding: 2px 6px;
    }
  </style>
</head>
