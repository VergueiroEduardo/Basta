<!-- ════════════════════════════════════════════════════════
     CONFIRMATION MODAL
     ════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="confirmModal">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal__eyebrow">Atenção</div>
    <h2 class="modal__title" id="modalTitle">Desconectar <span id="modalBankName"></span>?</h2>
    <p class="modal__desc">Ao desconectar, os dados desta conta não serão mais atualizados via Open Finance.</p>
    <div class="modal__actions">
      <button class="btn-modal-cancel" id="confirmCancel" onclick="closeConfirm()">Cancelar</button>
      <button class="btn-modal-confirm" id="confirmConfirm" onclick="confirmDisconnect()">Desconectar</button>
    </div>
  </div>
</div>

<script>
  let lastFocusedElementConfirm = null;
  let cardToRemove = null;

  function openConfirm(bankName) {
    lastFocusedElementConfirm = document.activeElement;
    // Guardar referência ao card que será removido
    cardToRemove = lastFocusedElementConfirm.closest('.account-card');
    document.getElementById('modalBankName').textContent = bankName;
    const modal = document.getElementById('confirmModal');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    // Mover foco para o primeiro botão
    document.getElementById('confirmCancel').focus();
  }

  function confirmDisconnect() {
    if (cardToRemove) {
      // Adicionar classe de remoção para animação
      cardToRemove.classList.add('account-removing');
      // Remover do DOM após animação
      setTimeout(function() {
        cardToRemove.remove();
        // Verificar se ainda há cards
        cardToRemove = null;
      }, 300);
    }
    closeConfirm();
  }

  function closeConfirm() {
    const modal = document.getElementById('confirmModal');
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    // Restaurar foco ao elemento que abriu o modal
    if (lastFocusedElementConfirm) {
      lastFocusedElementConfirm.focus();
    }
  }

  // Focus trap e Escape para fechar
  const confirmModal = document.getElementById('confirmModal');
  const confirmBox = confirmModal.querySelector('.modal');
  const confirmCancelBtn = document.getElementById('confirmCancel');
  const confirmConfirmBtn = document.getElementById('confirmConfirm');

  confirmModal.addEventListener('click', function(e) {
    if (e.target === this) closeConfirm();
  });

  confirmBox.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      e.preventDefault();
      closeConfirm();
    }

    if (e.key === 'Tab') {
      const focusableElements = [confirmCancelBtn, confirmConfirmBtn];
      const currentIndex = focusableElements.indexOf(document.activeElement);

      if (e.shiftKey) {
        // Shift + Tab (backward)
        e.preventDefault();
        const nextIndex = currentIndex === 0 ? focusableElements.length - 1 : currentIndex - 1;
        focusableElements[nextIndex].focus();
      } else {
        // Tab (forward)
        e.preventDefault();
        const nextIndex = currentIndex === focusableElements.length - 1 ? 0 : currentIndex + 1;
        focusableElements[nextIndex].focus();
      }
    }
  });
</script>

