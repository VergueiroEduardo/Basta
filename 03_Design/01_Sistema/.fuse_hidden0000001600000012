  <style>
    /* Hover-only: em devices touch (sem hover real), neutraliza estados hover
       que ficam "stuck" depois do tap (transform, translate). Cosmética; não toca em color/background. */

    /* ══════════════════════════════════════════════════════════
       RESET
       ══════════════════════════════════════════════════════════ */    body {
      font-family: var(--f);
      font-size: 16px;
      line-height: 1.6;
      color: var(--black);
      background: var(--off-white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    /* ══════════════════════════════════════════════════════════
       LAYOUT — sidebar + main
       ══════════════════════════════════════════════════════════ */
    .dashboard { display: flex; min-height: 100vh; min-height: 100dvh; }

    /* ── SIDEBAR ──────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w); background: var(--white);
      border-right: 1px solid var(--gray-300);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 50;
    }
    .sidebar__header { padding: 28px 24px 32px; }
    .sidebar__logo { height: 72px; width: auto; display: block; }

    .sidebar__nav { flex: 1; padding: 0 12px; }
    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px; font-size: 13px; font-weight: 500;
      color: var(--gray-600); transition: color var(--t), background var(--t);
      margin-bottom: 2px; position: relative;
    }
    .nav-item:hover { color: var(--black); background: var(--off-white); }
    .nav-item--active { color: var(--black); font-weight: 700; background: var(--off-white); }
    .nav-item--active::before {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; background: var(--green);
    }
    .nav-item__icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.6; }
    .nav-item--active .nav-item__icon { opacity: 1; }

    .sidebar__user {
      padding: 20px 24px; border-top: 1px solid var(--gray-300);
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar__avatar {
      width: 32px; height: 32px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; letter-spacing: 0.02em;
    }
    .sidebar__user-info { flex: 1; min-width: 0; }
    .sidebar__user-name { font-size: 12px; font-weight: 700; color: var(--black); line-height: 1.2; }
    .sidebar__user-email {
      font-size: 11px; color: var(--gray-600); font-weight: 400; line-height: 1.3;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sidebar__logout { color: var(--gray-300); transition: color var(--t); }
    .sidebar__logout:hover { color: var(--error); }

    /* ── MAIN ─────────────────────────────────────────────── */
    .main { flex: 1; }

    /* ── TOP BAR ──────────────────────────────────────────── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 60;
      background: var(--white); border-bottom: 1px solid var(--gray-300);
      padding: 14px 24px; align-items: center; justify-content: space-between;
    }
    .topbar__logo { height: 48px; width: auto; }
    .topbar__avatar {
      width: 28px; height: 28px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════════════════════════════
       PAGE HEADER
       ══════════════════════════════════════════════════════════ */
    .page-title {
      font-size: clamp(22px, 5vw, 32px); font-weight: 800; line-height: 1.1;
      letter-spacing: -0.02em; margin-bottom: 6px;
    }
    .accent { color: var(--black); }

    .page-desc {
      font-size: 13px; color: var(--gray-600); font-weight: 400;
      line-height: 1.5; margin-bottom: 32px;
    }

    /* ── CTA Conectar nova conta ──────────────────────────── */
    .btn-connect {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      padding: 18px 24px;
      background: var(--green); color: var(--white);
      font-family: var(--f); font-size: 12px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
      border: 2px solid var(--black);
      margin-top: 24px;
      transition: background var(--t), color var(--t);
    }
    .btn-connect:hover { background: var(--black); color: var(--white); }
    .btn-connect:active { transform: scale(0.98); }
    .btn-connect__plus {
      font-size: 16px; font-weight: 700; line-height: 1;
    }

    /* ══════════════════════════════════════════════════════════
       SECTION LABEL
       ══════════════════════════════════════════════════════════ */
    .section-label {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--black); margin-bottom: 16px;
    }

    /* ══════════════════════════════════════════════════════════
       ACCOUNT CARD
       ══════════════════════════════════════════════════════════ */
    .account-list {
      display: flex;
      flex-direction: column;
    }

    .account-card {
      background: var(--white);
      border: 1px solid var(--gray-300);
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: -1px;
      transition: background var(--t);
    }

    .account-card:first-child {
      border-top: 1px solid var(--gray-300);
    }

    .account-card:hover {
      background: var(--off-white);
    }

    /* Bank badge */
    .bank-badge {
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 800; color: var(--white);
      flex-shrink: 0; letter-spacing: 0.02em;
    }

    /* Bank info */
    .account-card__info { flex: 1; min-width: 0; }

    .account-card__name {
      font-weight: 700; font-size: 14px; color: var(--black); line-height: 1.3;
    }

    .account-card__details {
      font-size: 12px; color: var(--gray-600); font-weight: 400;
      line-height: 1.4; margin-top: 2px;
    }

    /* Status */
    .account-card__status {
      display: flex; flex-direction: column;
      align-items: flex-end; gap: 2px; flex-shrink: 0;
    }

    .account-card__status-label {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.04em; color: var(--green);
    }

    .account-card__status-sub {
      font-size: 11px; color: var(--gray-600); font-weight: 400;
      text-transform: uppercase; letter-spacing: 0.02em;
    }

    /* ── Icon action buttons + tooltip (padrão unificado) ── */
    .icon-btn {
      position: relative;
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      background: var(--white); color: var(--gray-600);
      border: 1px solid var(--gray-300);
      cursor: pointer; flex-shrink: 0;
      transition: color var(--t), border-color var(--t), background var(--t);
    }
    .icon-btn:hover { color: var(--black); border-color: var(--black); background: var(--off-white); }
    .icon-btn--danger:hover { color: var(--error); border-color: var(--error); background: var(--white); }
    .icon-btn::after {
      content: attr(data-tip);
      position: absolute;
      bottom: calc(100% + 7px);
      left: 50%; transform: translateX(-50%);
      background: var(--black); color: var(--white);
      font-size: 11px; font-weight: 700; font-family: var(--f);
      text-transform: uppercase; letter-spacing: 0.04em;
      white-space: nowrap;
      padding: 4px 8px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 10;
    }
    .icon-btn:hover::after { opacity: 1; }

    /* Account card removal animation */
    .account-card.account-removing {
      opacity: 0;
      transform: translateX(-20px);
      pointer-events: none;
    }

    /* ══════════════════════════════════════════════════════════
       CONFIRMATION MODAL
       ══════════════════════════════════════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .modal-overlay.is-open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--white);
      border: 2px solid var(--black);
      padding: 32px;
      width: 100%; max-width: 400px;
    }
    .modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--error); margin-bottom: 10px;
    }
    .modal__title {
      font-size: 18px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.2; margin-bottom: 10px;
    }
    .modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55;
      margin-bottom: 28px; text-wrap: pretty;
    }
    .modal__actions { display: flex; gap: 10px; justify-content: flex-end; }

    .btn-modal-cancel {
      padding: 10px 20px; font-family: var(--f); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer;
      background: transparent; color: var(--black);
      border: 2px solid var(--gray-300);
      transition: border-color var(--t), background var(--t);
    }
    .btn-modal-cancel:hover { border-color: var(--black); background: var(--off-white); }

    .btn-modal-confirm {
      padding: 10px 20px; font-family: var(--f); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer;
      background: var(--error); color: var(--white);
      border: 2px solid var(--error);
      transition: background var(--t), border-color var(--t);
    }
    .btn-modal-confirm:hover { background: #b91c1c; border-color: #b91c1c; }

    /* ══════════════════════════════════════════════════════════
       WHATSAPP FAB
       ══════════════════════════════════════════════════════════ */
    .fab {
      position: fixed; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      width: 68px; height: 68px;
      background: var(--green); border: 2px solid var(--black);
      border-radius: 0; color: var(--white); box-shadow: none;
      transition: background var(--t), color var(--t), border-color var(--t);
    }
    .fab:hover { background: var(--black); border-color: var(--black); }
    .fab__icon { width: 36px; height: 36px; flex-shrink: 0; }

    /* ══════════════════════════════════════════════════════════
       MOBILE-FIRST RESPONSIVE
       ══════════════════════════════════════════════════════════ */
    .sidebar { display: none; }
    .topbar { display: flex; }
    .main { padding: 84px 24px 100px; max-width: 100%; }
    .page-title { font-size: 22px; }
    .fab { bottom: max(16px, env(safe-area-inset-bottom)); right: 16px; }

    /* Mobile: account card compact */
    .account-card { padding: 16px; gap: 12px; }
    .bank-badge { width: 40px; height: 40px; font-size: 11px; }

    @media (min-width: 640px) {
      .main { padding: 84px 24px 100px; }
      .page-title { font-size: 26px; }
      .account-card { padding: 20px 24px; gap: 16px; }
      .bank-badge { width: 44px; height: 44px; font-size: 11px; }
    }

    @media (min-width: 960px) {
      .sidebar { display: flex; }
      .topbar  { display: none; }
      .main { margin-left: var(--sidebar-w); padding: 40px 40px 80px; max-width: 960px; }
      .page-title { font-size: 28px; }
      .account-card__name { font-size: 15px; }
      .account-card__details { font-size: 13px; }
      .fab { width: 80px; height: 80px; bottom: max(36px, env(safe-area-inset-bottom)); right: 36px; }
      .fab__icon { width: 40px; height: 40px; }
    }

    @media (min-width: 1200px) {
      .main { padding: 40px 48px 80px; }
    }

    @supports (padding: env(safe-area-inset-top)) {
      .topbar { padding-top: max(14px, env(safe-area-inset-top)); }
      .main { padding-bottom: max(100px, calc(80px + env(safe-area-inset-bottom))); }
      .fab { bottom: max(16px, calc(8px + env(safe-area-inset-bottom))); }
    }

    /* ── Close button ─────────────────────────────────────── */
    .btn-close {
      position: fixed; top: 0; right: 0; z-index: 80;
      width: 52px; height: 52px;
      display: flex; align-items: center; justify-content: center;
      background: transparent; color: var(--gray-600);
      transition: color var(--t), background var(--t);
    }
    .btn-close:hover { color: var(--black); background: rgba(0,0,0,0.05); }
    /* hide avatar — close takes its place on mobile */
    .topbar__avatar { display: none !important; }

    @media (min-width: 768px) {
      .btn-close {
        width: 36px; height: 36px;
        top: 20px; right: 28px;
        background: var(--white);
        border: 1.5px solid var(--gray-300);
        color: var(--black);
      }
      .btn-close:hover { background: var(--off-white); border-color: var(--black); }
    }

    /* ══════════════════════════════════════════════════════════
       LOGOUT MODAL
       ══════════════════════════════════════════════════════════ */
    .logout-overlay {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .logout-overlay.is-open { opacity: 1; pointer-events: all; }

    .logout-modal {
      background: var(--white);
      border: 2px solid var(--black);
      padding: 28px 28px 24px;
      width: 100%; max-width: 360px;
    }
    .logout-modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--error);
      margin-bottom: 8px;
    }
    .logout-modal__title {
      font-size: 20px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.15; margin-bottom: 8px;
    }
    .logout-modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55;
      margin-bottom: 24px;
    }
    .logout-modal__actions {
      display: flex; gap: 10px; justify-content: flex-end;
    }
    .btn-logout-cancel {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--black); cursor: pointer;
      border: 1.5px solid var(--gray-300);
      transition: border-color var(--t), background var(--t);
    }
    .btn-logout-cancel:hover { border-color: var(--black); background: var(--off-white); }
    .btn-logout-confirm {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--error); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--error);
      transition: background var(--t), border-color var(--t);
    }    .btn-modal-cancel:active, .btn-modal-confirm:active, .btn-close:active, .btn-logout-cancel:active, .btn-logout-confirm:active { transform: scale(0.98); }


  </style>
</head>
