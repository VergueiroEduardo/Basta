<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Basta. — CRM</title>
  <meta name="theme-color" content="#000000" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- BASTA FOUNDATION INJECTED -->
  <link rel="stylesheet" href="_foundation/tokens.css" />
  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_components/btn.css" />
  <link rel="stylesheet" href="_components/modal.css" />
  <link rel="stylesheet" href="_components/sidebar.css" />
  <link rel="stylesheet" href="_components/topbar.css" />
  <link rel="stylesheet" href="_components/badge.css" />
  <style>
    /* ══════════════════════════════════════════════════════════
       RESET LOCAL
       ══════════════════════════════════════════════════════════ */    body {
      font-family: var(--f);
      font-size: 16px;
      line-height: 1.6;
      color: var(--black);
      background: var(--off-white);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }    /* ══════════════════════════════════════════════════════════
       LAYOUT (mesma sidebar do design system)
       ══════════════════════════════════════════════════════════ */
    .dashboard { display: flex; min-height: 100vh; min-height: 100dvh; }

    .sidebar {
      width: var(--sidebar-w); background: var(--white);
      border-right: 1px solid var(--gray-300);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 50;
      overflow-y: auto;
    }
    .sidebar__header { padding: 28px 24px 32px; }
    .sidebar__logo { height: 72px; width: auto; display: block; }
    .sidebar__nav { flex: 1; padding: 0 12px; }
    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px; font-size: 13px; font-weight: 500;
      color: var(--gray-600); transition: color var(--t), background var(--t);
      margin-bottom: 2px; position: relative;
    }
    .nav-item:hover { color: var(--black); background: var(--off-white); }
    .nav-item--active { color: var(--black); font-weight: 700; background: var(--off-white); }
    .nav-item--active::before {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; background: var(--green);
    }
    .nav-item__icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.6; }
    .nav-item--active .nav-item__icon { opacity: 1; }

    .sidebar__section-title {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.14em; color: var(--gray-600);
      padding: 24px 16px 8px; margin-top: 12px;
      border-top: 1px solid var(--gray-200);
    }

    .sidebar__user {
      padding: 20px 24px; border-top: 1px solid var(--gray-300);
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar__avatar {
      width: 32px; height: 32px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; letter-spacing: 0.02em;
    }
    .sidebar__user-info { flex: 1; min-width: 0; }
    .sidebar__user-name { font-size: 12px; font-weight: 700; color: var(--black); line-height: 1.2; }
    .sidebar__user-email {
      font-size: 11px; color: var(--gray-600); font-weight: 400; line-height: 1.3;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sidebar__logout { color: var(--gray-300); transition: color var(--t); }
    .sidebar__logout:hover { color: var(--error); }

    .main { flex: 1; }

    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 60;
      background: var(--white); border-bottom: 1px solid var(--gray-300);
      padding: 14px 24px; align-items: center; justify-content: space-between;
    }
    .topbar__logo { height: 48px; width: auto; }
    .topbar__avatar {
      width: 28px; height: 28px; background: var(--green); color: var(--white);
      font-size: 11px; font-weight: 800; display: flex; align-items: center;
      justify-content: center; letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════════════════════════════
       PAGE HEADER
       ══════════════════════════════════════════════════════════ */
    .page-head {
      display: flex; align-items: flex-end; justify-content: space-between;
      gap: 16px; margin-bottom: 24px; flex-wrap: wrap;
    }
    .page-title {
      font-size: clamp(22px, 5vw, 32px); font-weight: 800; line-height: 1.1;
      letter-spacing: -0.02em; margin-bottom: 6px;
    }
    .page-title .accent { color: var(--green); }
    .page-desc {
      font-size: 13px; color: var(--gray-600); font-weight: 400; line-height: 1.5;
    }

    /* ══════════════════════════════════════════════════════════
       SCORECARD STRIP — KPIs do funil
       ══════════════════════════════════════════════════════════ */
    .kpis {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    @media (min-width: 720px) { .kpis { grid-template-columns: repeat(4, 1fr); } }
    .kpi {
      background: var(--white); border: 1px solid var(--gray-300);
      padding: 16px;
    }
    .kpi__label {
      font-size: 10px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-600);
    }
    .kpi__value {
      font-size: 28px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.05; margin: 4px 0 4px;
      color: var(--black); font-variant-numeric: tabular-nums;
    }
    .kpi__delta {
      font-size: 11px; font-weight: 700;
      display: inline-flex; align-items: center; gap: 4px;
    }
    .kpi__delta--up { color: var(--green); }
    .kpi__delta--down { color: var(--error); }
    .kpi__delta--flat { color: var(--gray-600); }

    /* ══════════════════════════════════════════════════════════
       FILTER BAR
       ══════════════════════════════════════════════════════════ */
    .filters {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 16px; flex-wrap: wrap;
    }
    .filter-search {
      position: relative; flex: 1; min-width: 220px;
    }
    .filter-search__input {
      width: 100%; padding: 10px 12px 10px 38px;
      font-family: var(--f); font-size: 13px;
      border: 1px solid var(--gray-300); background: var(--white);
      transition: border-color var(--t);
    }
    .filter-search__input:focus { outline: none; border-color: var(--black); }
    .filter-search__icon {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      color: var(--gray-300); pointer-events: none;
    }
    .filter-pill {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 14px;
      font-family: var(--f); font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--gray-600);
      border: 1.5px solid var(--gray-300);
      transition: all var(--t); cursor: pointer; white-space: nowrap;
    }
    .filter-pill:hover { color: var(--black); border-color: var(--black); }
    .filter-pill--active {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .filter-pill svg { width: 12px; height: 12px; }

    .filter-divider {
      display: inline-block;
      width: 1px; height: 20px;
      background: var(--gray-300);
      margin: 0 4px;
    }
    .health-dot {
      display: inline-block;
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0;
    }
    .health-dot--ok { background: var(--green); }
    .health-dot--watch { background: var(--warning); }
    .health-dot--cold { background: var(--error); }
    .filter-pill[data-group="health"].filter-pill--active .health-dot--ok { box-shadow: 0 0 0 2px rgba(255,255,255,0.6); }
    .filter-pill[data-group="health"].filter-pill--active { /* mantém pill com fundo preto, dot mais legível */ }

    /* Drag-and-drop states */
    .lead-card[draggable="true"] { cursor: grab; user-select: none; }
    .lead-card[draggable="true"]:active { cursor: grabbing; }
    .lead-card.is-dragging {
      opacity: 0.4;
      transform: scale(0.98);
    }
    .col.is-drop-target {
      outline: 2px dashed var(--green);
      outline-offset: -2px;
    }
    .col.is-drop-target .col__body {
      background: rgba(66,180,73,0.06);
    }

    .view-toggle {
      display: inline-flex; border: 1.5px solid var(--gray-300);
    }
    .view-toggle__btn {
      padding: 8px 12px;
      font-family: var(--f); font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--gray-600);
      cursor: pointer; transition: all var(--t);
      display: inline-flex; align-items: center; gap: 5px;
    }
    .view-toggle__btn:hover { color: var(--black); }
    .view-toggle__btn--active { background: var(--black); color: var(--white); }
    .view-toggle__btn svg { width: 12px; height: 12px; }

    /* ══════════════════════════════════════════════════════════
       KANBAN BOARD
       ══════════════════════════════════════════════════════════ */
    .board-wrap {
      /* SCROLL HORIZONTAL aqui (passa entre colunas) — vertical fica nas colunas */
      overflow-x: auto;
      overflow-y: hidden;
      margin: 0 -16px;
      padding: 0 16px 16px;
      /* altura fixa do board → o scroll vertical fica obrigatoriamente dentro de cada coluna */
      height: calc(100vh - 320px);
      height: calc(100dvh - 320px);
      min-height: 520px;
      scrollbar-width: thin;
      scrollbar-color: var(--gray-300) transparent;
    }
    .board-wrap::-webkit-scrollbar { height: 10px; }
    .board-wrap::-webkit-scrollbar-track {
      background: var(--off-white);
      border-top: 1px solid var(--gray-200);
    }
    .board-wrap::-webkit-scrollbar-thumb {
      background: var(--gray-300);
      border-radius: 4px;
    }
    .board-wrap::-webkit-scrollbar-thumb:hover { background: var(--gray-600); }

    @media (min-width: 960px) {
      .board-wrap {
        margin: 0;
        padding: 0 0 16px;
        height: calc(100vh - 260px);
        height: calc(100dvh - 260px);
      }
    }

    .board {
      display: flex;
      flex-direction: row;
      gap: 18px;
      align-items: stretch;         /* colunas alinhadas no grid — mesma altura */
      height: 100%;
      padding-right: 40px;          /* respiro após a última coluna no fim do scroll —
                                       em flex-row, padding-right é parte do conteúdo
                                       rolável (cross-browser, ao contrário do grid) */
    }
    /* sentinela explícita: garante o respiro mesmo se o padding-right
       for ignorado por algum container ancestor */
    .board__end-spacer {
      flex: 0 0 1px;
      width: 1px;
      height: 100%;
      pointer-events: none;
    }

    .col {
      display: flex; flex-direction: column;
      background: var(--white);
      border: 1px solid var(--gray-300);
      height: 100%;
      min-height: 0;               /* essencial para o overflow do filho funcionar */
      flex: 0 0 300px;             /* largura fixa de 300px, sem encolher nem crescer */
    }
    .col__head {
      padding: 16px 16px 14px;
      border-bottom: 2px solid var(--black);
      background: var(--white);
      position: sticky; top: 0; z-index: 2;
      flex-shrink: 0;              /* header fixo não encolhe sob pressão */
    }
    .col__top {
      display: flex; align-items: center; justify-content: space-between;
      gap: 8px; margin-bottom: 6px;
    }
    .col__num {
      font-size: 10px; font-weight: 800;
      letter-spacing: 0.06em;
      color: var(--gray-600);
      font-variant-numeric: tabular-nums;
    }
    .col__count {
      font-size: 11px; font-weight: 800;
      color: var(--white); background: var(--black);
      padding: 2px 8px;
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
    }
    .col__title {
      font-size: 13px; font-weight: 800;
      letter-spacing: -0.01em; color: var(--black);
      line-height: 1.2;
    }
    .col__sub {
      font-size: 10px; color: var(--gray-600); font-weight: 600;
      margin-top: 4px; letter-spacing: 0.02em;
    }
    .col__sub strong { color: var(--black); font-weight: 800; }

    /* color accent per stage */
    .col[data-stage="1"] .col__head { border-bottom-color: var(--blue); }
    .col[data-stage="2"] .col__head { border-bottom-color: var(--blue); }
    .col[data-stage="3"] .col__head { border-bottom-color: var(--warning); }
    .col[data-stage="4"] .col__head { border-bottom-color: var(--warning); }
    .col[data-stage="5"] .col__head { border-bottom-color: var(--warning); }
    .col[data-stage="6"] .col__head { border-bottom-color: var(--warning); }
    .col[data-stage="7"] .col__head { border-bottom-color: var(--sage); }
    .col[data-stage="8"] .col__head { border-bottom-color: var(--sage); }
    .col[data-stage="9"] .col__head { border-bottom-color: var(--green); }

    .col__body {
      padding: 14px;
      overflow-y: auto;
      overflow-x: hidden;
      display: flex; flex-direction: column; gap: 12px;
      flex: 1;
      min-height: 0;               /* dispara o scroll interno em flex */
      background: var(--off-white);
      scrollbar-width: thin;
      scrollbar-color: var(--gray-300) transparent;
    }
    .col__body::-webkit-scrollbar { width: 6px; }
    .col__body::-webkit-scrollbar-track { background: transparent; }
    .col__body::-webkit-scrollbar-thumb {
      background: var(--gray-300);
      border-radius: 3px;
    }
    .col__body::-webkit-scrollbar-thumb:hover { background: var(--gray-600); }

    /* ── CARD DE LEAD ──────────────────────────────────────── */
    .lead-card {
      background: var(--white);
      border: 1px solid var(--gray-300);
      padding: 12px;
      display: flex; flex-direction: column; gap: 8px;
      cursor: grab;
      transition: border-color var(--t), transform var(--t);
      flex-shrink: 0;               /* card mantém altura natural — nunca encolhe pra caber */
    }
    .lead-card:hover { border-color: var(--black); }
    .lead-card:active { cursor: grabbing; transform: scale(0.99); }

    .lead-card__top {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 8px;
    }
    .lead-card__name {
      font-size: 13px; font-weight: 800;
      color: var(--black); letter-spacing: -0.01em;
      line-height: 1.2;
    }
    .lead-card__phone {
      font-size: 11px; color: var(--gray-600); font-weight: 600;
      margin-top: 2px;
      font-variant-numeric: tabular-nums;
    }

    .lead-card__health {
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0; margin-top: 4px;
    }
    .lead-card__health--ok    { background: var(--green); }
    .lead-card__health--watch { background: var(--warning); }
    .lead-card__health--cold  { background: var(--error); }

    .lead-card__meta {
      display: flex; gap: 8px; flex-wrap: wrap;
      font-size: 10px; color: var(--gray-600); font-weight: 600;
      padding-top: 8px; border-top: 1px dashed var(--gray-200);
    }
    .lead-card__meta-item {
      display: inline-flex; align-items: center; gap: 4px;
    }
    .lead-card__meta-item svg { width: 10px; height: 10px; }
    .lead-card__meta-item strong {
      color: var(--black); font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    .lead-card__actions {
      display: flex; gap: 6px; margin-top: 4px;
    }
    .lead-card__btn {
      flex: 1;
      padding: 7px 10px;
      font-family: var(--f); font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--black);
      border: 1px solid var(--gray-300);
      transition: all var(--t); cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; gap: 4px;
    }
    .lead-card__btn:hover { border-color: var(--black); background: var(--off-white); }
    .lead-card__btn--primary {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .lead-card__btn--primary:hover { background: var(--green); border-color: var(--green); }
    .lead-card__btn svg { width: 10px; height: 10px; }

    .lead-card__source {
      display: inline-block;
      font-size: 9px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--gray-600);
      padding: 2px 6px;
      border: 1px solid var(--gray-300);
    }

    /* placeholder de coluna vazia */
    .col__empty {
      padding: 20px 12px;
      text-align: center;
      font-size: 11px; color: var(--gray-600);
      border: 1px dashed var(--gray-300);
      background: var(--white);
    }

    /* ══════════════════════════════════════════════════════════
       LIST VIEW — visão complementar ao Kanban
       ══════════════════════════════════════════════════════════ */
    .list-view {
      background: var(--white);
      border: 1px solid var(--gray-300);
      overflow: hidden;
    }
    .list-scroll {
      overflow-x: auto;
      scrollbar-width: thin;
    }
    .list-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1080px;
    }
    .list-table thead th {
      font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--gray-600);
      text-align: left;
      padding: 14px 16px;
      background: var(--off-white);
      border-bottom: 1px solid var(--gray-300);
      white-space: nowrap;
      vertical-align: middle;
    }
    .list-table thead th.is-sortable { cursor: pointer; user-select: none; }
    .list-table thead th.is-sortable:hover { color: var(--black); }
    .list-table thead th.is-sortable svg {
      width: 10px; height: 10px; vertical-align: -1px;
      margin-left: 3px; opacity: 0.5;
    }
    .list-table thead th.col-check { width: 36px; padding-right: 0; }
    .list-table thead th.col-actions { width: 40px; }

    .list-table tbody tr {
      border-bottom: 1px solid var(--gray-200);
      transition: background var(--t);
    }
    .list-table tbody tr:last-child { border-bottom: none; }
    .list-table tbody tr:hover { background: var(--off-white); }
    .list-table tbody tr.is-selected {
      background: rgba(66,180,73,0.06);
      box-shadow: inset 3px 0 0 var(--green);
    }
    .list-table tbody td {
      padding: 14px 16px;
      font-size: 13px;
      color: var(--black);
      vertical-align: middle;
    }

    /* Section divider rows (etapa headers when sorted/grouped) */
    .list-section-row td {
      padding: 18px 16px 8px;
      background: var(--off-white);
      border-top: 2px solid var(--black);
      border-bottom: none;
    }
    .list-section-row td > div {
      display: flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--black);
    }
    .list-section-row__num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 22px; height: 22px;
      background: var(--white); border: 1.5px solid var(--black);
      font-size: 10px; font-variant-numeric: tabular-nums;
    }
    .list-section-row__count {
      margin-left: auto;
      font-size: 10px; font-weight: 800;
      letter-spacing: 0.04em;
      color: var(--gray-600);
    }

    /* Lead cell (avatar + name + phone) */
    .lead-cell {
      display: flex; align-items: center; gap: 12px;
      min-width: 220px;
    }
    .lead-cell__avatar {
      position: relative;
      width: 32px; height: 32px;
      background: var(--gray-200); color: var(--black);
      font-size: 10px; font-weight: 800; letter-spacing: 0.02em;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .lead-cell__health-dot {
      position: absolute; bottom: -2px; right: -2px;
      width: 10px; height: 10px;
      border: 2px solid var(--white);
      border-radius: 50%;
      background: var(--gray-300);
    }
    .lead-cell__health-dot--ok { background: var(--green); }
    .lead-cell__health-dot--watch { background: var(--warning); }
    .lead-cell__health-dot--cold { background: var(--error); }

    .lead-cell__body { min-width: 0; }
    .lead-cell__name {
      font-size: 13px; font-weight: 700; color: var(--black);
      line-height: 1.25;
    }
    .lead-cell__phone {
      font-size: 11px; color: var(--gray-600); font-weight: 600;
      margin-top: 2px;
      font-variant-numeric: tabular-nums;
    }

    /* Stage chip (mini, in list) */
    .stage-chip-list {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 8px 4px 4px;
      font-size: 11px; font-weight: 700;
      color: var(--black);
      background: var(--off-white);
      border: 1px solid var(--gray-300);
      max-width: 100%;
    }
    .stage-chip-list__num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 18px; height: 18px;
      font-size: 9px; font-weight: 800;
      background: var(--white); border: 1px solid var(--gray-300);
      color: var(--black);
    }
    .stage-chip-list__name {
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .stage-chip-list[data-stage="1"] .stage-chip-list__num,
    .stage-chip-list[data-stage="2"] .stage-chip-list__num { border-color: var(--blue); color: var(--blue); }
    .stage-chip-list[data-stage="3"] .stage-chip-list__num,
    .stage-chip-list[data-stage="4"] .stage-chip-list__num,
    .stage-chip-list[data-stage="5"] .stage-chip-list__num,
    .stage-chip-list[data-stage="6"] .stage-chip-list__num { border-color: var(--warning); color: var(--warning); }
    .stage-chip-list[data-stage="7"] .stage-chip-list__num,
    .stage-chip-list[data-stage="8"] .stage-chip-list__num { border-color: var(--sage); color: #6B7048; }
    .stage-chip-list[data-stage="9"] .stage-chip-list__num { background: var(--green); border-color: var(--green); color: var(--white); }

    /* Source pill */
    .source-pill {
      display: inline-block;
      font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--gray-600);
      padding: 2px 7px;
      border: 1px solid var(--gray-300);
      white-space: nowrap;
    }

    /* Time / activity */
    .time-cell {
      font-size: 12px; color: var(--gray-600); font-weight: 500;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .time-cell strong { color: var(--black); font-weight: 700; }
    .time-cell--alert strong { color: var(--warning); }
    .time-cell--cold strong { color: var(--error); }

    .activity-cell {
      display: flex; flex-direction: column; gap: 2px;
      min-width: 180px;
    }
    .activity-cell__what {
      font-size: 12px; color: var(--black); font-weight: 600;
      line-height: 1.35;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      max-width: 220px;
    }
    .activity-cell__when {
      font-size: 10px; color: var(--gray-600); font-weight: 600;
      letter-spacing: 0.04em; text-transform: uppercase;
    }

    /* Assignee */
    .assignee {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700;
      color: var(--black);
    }
    .assignee__dot {
      width: 18px; height: 18px;
      background: var(--gray-200); color: var(--black);
      font-size: 9px; font-weight: 800; letter-spacing: 0.02em;
      display: inline-flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .assignee__dot--admin { background: var(--black); color: var(--white); }
    .assignee__dot--bot { background: var(--blue); color: var(--white); }
    .assignee--none { color: var(--gray-600); font-weight: 500; font-style: italic; }

    /* Checkbox (re-used pattern) */
    .row-check { width: 36px; padding-right: 0; }
    .check {
      appearance: none;
      width: 16px; height: 16px;
      border: 1.5px solid var(--gray-300);
      background: var(--white);
      cursor: pointer;
      position: relative;
      transition: border-color var(--t), background var(--t);
      vertical-align: middle;
    }
    .check:hover { border-color: var(--black); }
    .check:checked {
      background: var(--black); border-color: var(--black);
    }
    .check:checked::after {
      content: '';
      position: absolute; left: 4px; top: 1px;
      width: 5px; height: 9px;
      border: solid var(--white);
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }

    /* Kebab (mini, re-used) */
    .kebab-mini {
      width: 32px; height: 32px;
      display: inline-flex; align-items: center; justify-content: center;
      background: transparent; border: 1px solid transparent;
      color: var(--gray-600); cursor: pointer;
      transition: all var(--t);
    }
    .kebab-mini:hover { border-color: var(--gray-300); color: var(--black); background: var(--white); }
    .kebab-mini svg { width: 16px; height: 16px; }

    /* Pagination */
    .list-foot {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px; padding: 14px 16px;
      border-top: 1px solid var(--gray-300);
      font-size: 12px; color: var(--gray-600);
      flex-wrap: wrap;
      background: var(--off-white);
    }
    .list-foot strong { color: var(--black); font-weight: 700; }
    .list-foot__nav { display: flex; gap: 4px; }
    .list-foot__btn {
      padding: 6px 10px;
      font-family: var(--f); font-size: 11px; font-weight: 700;
      background: var(--white); color: var(--black);
      border: 1px solid var(--gray-300);
      cursor: pointer; transition: all var(--t);
      min-width: 32px;
    }
    .list-foot__btn:hover { border-color: var(--black); }
    .list-foot__btn--active {
      background: var(--black); color: var(--white); border-color: var(--black);
    }
    .list-foot__btn:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Group toggle (Agrupar por etapa) */
    .group-toggle {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 12px;
      font-family: var(--f); font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--white); color: var(--black);
      border: 1.5px solid var(--gray-300);
      cursor: pointer; transition: all var(--t);
    }
    .group-toggle:hover { border-color: var(--black); }
    .group-toggle.is-active { background: var(--black); color: var(--white); border-color: var(--black); }
    .group-toggle svg { width: 11px; height: 11px; }

    /* List header bar */
    .list-head-bar {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px; padding: 14px 16px;
      border-bottom: 1px solid var(--gray-300);
      background: var(--white);
      flex-wrap: wrap;
    }
    .list-head-bar__title {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-600);
    }
    .list-head-bar__title strong { color: var(--black); font-weight: 800; }
    .list-head-bar__right { display: flex; gap: 8px; }

    /* Group rows hidden when not grouped */
    .list-table[data-grouped="false"] .list-section-row { display: none; }

    /* View pane visibility */
    [data-view-pane] { display: block; }
    [data-view-pane].is-hidden { display: none; }

    /* Mobile: list scrolls horizontally */
    @media (max-width: 720px) {
      .list-head-bar { padding: 12px 14px; }
      .group-toggle { padding: 6px 10px; }
    }

    /* ══════════════════════════════════════════════════════════
       MOBILE-FIRST RESPONSIVE
       ══════════════════════════════════════════════════════════ */
    .sidebar { display: none; }
    .topbar  { display: flex; }
    .main    { padding: 72px 16px 60px; max-width: 100%; }
    .page-title { font-size: 22px; }

    @media (min-width: 640px) {
      .main { padding: 72px 24px 80px; }
      .page-title { font-size: 26px; }
    }

    @media (min-width: 960px) {
      .sidebar { display: flex; }
      .topbar  { display: none; }
      .main    { margin-left: var(--sidebar-w); padding: 32px 32px 60px; max-width: 100%; }
      .page-title { font-size: 28px; }
    }

    @media (min-width: 1280px) {
      .main { padding: 32px 40px 60px; }
      /* board mantém largura fixa de coluna (300px) e scroll horizontal —
         9 etapas não cabem em uma viewport sem espremer cards */
    }

    @supports (padding: env(safe-area-inset-top)) {
      .topbar { padding-top: max(14px, env(safe-area-inset-top)); }
      .main   { padding-bottom: max(60px, calc(40px + env(safe-area-inset-bottom))); }
    }

    /* ══════════════════════════════════════════════════════════
       LOGOUT MODAL
       ══════════════════════════════════════════════════════════ */
    .logout-overlay {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(26,26,26,0.55);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s var(--ease);
    }
    .logout-overlay.is-open { opacity: 1; pointer-events: all; }
    .logout-modal {
      background: var(--white); border: 2px solid var(--black);
      padding: 28px 28px 24px; width: 100%; max-width: 360px;
    }
    .logout-modal__eyebrow {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--error); margin-bottom: 8px;
    }
    .logout-modal__title {
      font-size: 20px; font-weight: 800; letter-spacing: -0.02em;
      line-height: 1.15; margin-bottom: 8px;
    }
    .logout-modal__desc {
      font-size: 13px; color: var(--gray-600); line-height: 1.55; margin-bottom: 24px;
    }
    .logout-modal__actions { display: flex; gap: 10px; justify-content: flex-end; }
    .btn-logout-cancel {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: transparent; color: var(--black); cursor: pointer;
      border: 1.5px solid var(--gray-300);
      transition: border-color var(--t), background var(--t);
    }
    .btn-logout-cancel:hover { border-color: var(--black); background: var(--off-white); }
    .btn-logout-confirm {
      padding: 10px 18px; font-family: var(--f); font-size: 11px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--error); color: var(--white); cursor: pointer;
      border: 1.5px solid var(--error);
      transition: background var(--t), border-color var(--t);
    }    /* nav-item placeholder "em breve" — sem destino ainda */
    .nav-item--soon { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
    .nav-item--soon::after {
      content: "Em breve";
      margin-left: auto;
      font-size: 9px; font-weight: 800;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--gray-600);
      border: 1px solid var(--gray-300); padding: 2px 6px;
    }
  </style>
</head>
