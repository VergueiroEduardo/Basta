    <div class="logout-modal__eyebrow">Confirmação</div>
    <h2 class="logout-modal__title" id="logoutTitle">Sair da conta?</h2>
    <p class="logout-modal__desc">Você precisará fazer login novamente para acessar sua área.</p>
    <div class="logout-modal__actions">
      <button class="btn-logout-cancel" id="logoutCancel" onclick="closeLogout()">Cancelar</button>
      <button class="btn-logout-confirm" id="logoutConfirm" onclick="window.location.href='03_basta-login.html'">Sair</button>
    </div>
  </div>
