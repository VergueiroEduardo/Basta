<script>
  /* ── Filter pill toggle (período = mutex, saúde = multi-select) ─ */
  document.querySelectorAll('.filter-pill').forEach(function(pill){
    pill.addEventListener('click', function(){
      var group = pill.dataset.group;
      if (group === 'period') {
        document.querySelectorAll('.filter-pill[data-group="period"]').forEach(function(p){
          p.classList.remove('filter-pill--active');
        });
        pill.classList.add('filter-pill--active');
      } else if (group === 'health') {
        pill.classList.toggle('filter-pill--active');
        applyHealthFilter();
      }
    });
  });

  function applyHealthFilter() {
    var active = Array.from(document.querySelectorAll('.filter-pill[data-group="health"].filter-pill--active'))
      .map(function(p){ return p.dataset.health; });
    document.querySelectorAll('.lead-card').forEach(function(card){
      // pula placeholders ("Ver todos")
      var phone = card.querySelector('.lead-card__phone');
      if (phone && phone.textContent.trim() === 'Ver todos') return;
      var dot = card.querySelector('.lead-card__health');
      if (!dot) return;
      var h = dot.classList.contains('lead-card__health--ok') ? 'ok'
            : dot.classList.contains('lead-card__health--watch') ? 'watch'
            : dot.classList.contains('lead-card__health--cold') ? 'cold' : '';
      // se nenhum filtro ativo, mostra todos
      if (active.length === 0 || active.indexOf(h) !== -1) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }

  /* ── Drag-and-drop entre colunas do Kanban ──────────────── */
  var draggedCard = null;

  function isPlaceholder(card) {
    var phone = card.querySelector('.lead-card__phone');
    return phone && phone.textContent.trim() === 'Ver todos';
  }

  document.querySelectorAll('.lead-card').forEach(function(card){
    if (isPlaceholder(card)) return;
    card.draggable = true;
    card.addEventListener('dragstart', function(e){
      draggedCard = card;
      card.classList.add('is-dragging');
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = 'move';
        try { e.dataTransfer.setData('text/plain', ''); } catch(_) {}
      }
    });
    card.addEventListener('dragend', function(){
      card.classList.remove('is-dragging');
      draggedCard = null;
      document.querySelectorAll('.col.is-drop-target').forEach(function(c){ c.classList.remove('is-drop-target'); });
    });
  });

  document.querySelectorAll('.col').forEach(function(col){
    var body = col.querySelector('.col__body');
    if (!body) return;
    col.addEventListener('dragover', function(e){
      if (!draggedCard) return;
      e.preventDefault();
      if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
      col.classList.add('is-drop-target');
    });
    col.addEventListener('dragleave', function(e){
      // só limpa se o cursor saiu de fato da coluna (não filhos)
      if (e.relatedTarget && col.contains(e.relatedTarget)) return;
      col.classList.remove('is-drop-target');
    });
    col.addEventListener('drop', function(e){
      e.preventDefault();
      col.classList.remove('is-drop-target');
      if (!draggedCard) return;
      var fromCol = draggedCard.closest('.col');
      // insere antes do placeholder "Ver todos" (se existir)
      var placeholder = Array.from(body.querySelectorAll('.lead-card')).find(isPlaceholder);
      if (placeholder) body.insertBefore(draggedCard, placeholder);
      else body.appendChild(draggedCard);
      // atualiza contadores das colunas afetadas
      [fromCol, col].forEach(updateColCount);
    });
  });

  function updateColCount(col) {
    if (!col) return;
    var cards = col.querySelectorAll('.lead-card');
    var realCount = 0;
    cards.forEach(function(c){ if (!isPlaceholder(c)) realCount++; });
    var countEl = col.querySelector('.col__count');
    if (countEl) countEl.textContent = realCount;
  }

  /* ── View toggle (Kanban / Lista) ────────────────────────── */
  document.querySelectorAll('.view-toggle__btn').forEach(function(b){
    b.addEventListener('click', function(){
      var view = b.dataset.view;
      document.querySelectorAll('.view-toggle__btn').forEach(function(x){ x.classList.remove('view-toggle__btn--active'); });
      b.classList.add('view-toggle__btn--active');
      document.querySelectorAll('[data-view-pane]').forEach(function(p){
        if (p.dataset.viewPane === view) p.classList.remove('is-hidden');
        else p.classList.add('is-hidden');
      });
    });
  });

  /* ── Agrupar por etapa ───────────────────────────────────── */
  function toggleGroup() {
    var btn = document.getElementById('groupToggle');
    var table = document.getElementById('leadsTable');
    var grouped = table.dataset.grouped === 'true';
    table.dataset.grouped = grouped ? 'false' : 'true';
    btn.classList.toggle('is-active');
  }

  /* ── Logout modal ────────────────────────────────────────── */
  let lastFocusedElement = null;
  function openLogout() {
    lastFocusedElement = document.activeElement;
    const modal = document.getElementById('logoutModal');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.getElementById('logoutCancel').focus();
  }
  function closeLogout() {
    const modal = document.getElementById('logoutModal');
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    if (lastFocusedElement) lastFocusedElement.focus();
  }
  const logoutModal = document.getElementById('logoutModal');
  logoutModal.addEventListener('click', function(e){ if (e.target === this) closeLogout(); });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && document.getElementById('logoutModal').classList.contains('is-open')) closeLogout();
  });
</script>

