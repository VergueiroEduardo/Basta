      .cta-actions .btn { width: auto; }
    }
    @media (min-width: 768px) { .section-cta { padding: 120px 0; } }
    /* ══════════════════════════════════════════════════════════
       FOOTER
    ══════════════════════════════════════════════════════════ */
    .site-footer {
      background: var(--white);
      border-top: 1px solid var(--gray-300);
      padding: 64px 0 48px;
    }
    .footer-logo-svg {
      height: clamp(80px, 14vw, 140px);
      width: auto;
      margin-bottom: 32px;
    }
    .footer-grid {
      display: grid; grid-template-columns: 1fr;
      gap: 32px; margin-bottom: 40px;
    }
    .footer-tagline {
      font-size: 16px; font-weight: 400;
      color: var(--gray-600); margin-top: 12px;
      max-width: 28ch; line-height: 1.5;
    }
    .footer-col-title {
      font-size: 14px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--black); margin-bottom: 10px;
    }
    .footer-links { list-style: none; }
    .footer-links li + li { margin-top: 6px; }
    .footer-links a {
      font-size: 15px; font-weight: 400; color: var(--gray-600);
      transition: color var(--t);
    }
    .footer-links a:hover { color: var(--black); }
    .footer-contact {
      font-size: 15px; font-weight: 400;
      color: var(--gray-600); line-height: 1.5;
      display: flex; flex-direction: column;
      gap: 10px;
    }
    .footer-contact a {
      display: inline-block;
      width: fit-content;
      transition: color var(--t);
    }
    .footer-contact a:hover { color: var(--black); }
    .footer-bottom {
      padding-top: 32px; border-top: 1px solid var(--gray-300);
      display: flex; flex-direction: column; gap: 16px;
    }
    .footer-copy {
      font-size: 14px; font-weight: 500;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--gray-600);
    }
    .footer-social { display: flex; gap: 16px; align-items: center; }
    .footer-social a {
      display: flex; align-items: center; justify-content: center;
      width: 44px; height: 44px;
      color: var(--gray-600);
      transition: color var(--t), transform var(--t);
    }
    .footer-social a:hover { color: var(--black); transform: translateY(-2px); }
    .footer-social svg { display: block; }

    /* ── NVIDIA Inception badge ─────────────────────────────── */
    .footer-badge {
      display: inline-flex;
      align-items: center;
      opacity: 0.85;
      transition: opacity var(--t);
      /* Badge original tem fundo branco + texto preto. Sobre o footer branco fica
         redundante o fundo; este filtro mantém apenas o desenho preto. */
    }
    .footer-badge:hover { opacity: 1; }
    .footer-badge img {
      display: block;
      width: 140px;
      height: auto;
      /* Mantém a aparência preta original (sem alterar o asset) */
      filter: contrast(1) saturate(0);
    }

    @media (min-width: 768px) {
      .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 64px; }
      .footer-bottom {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 32px;
        align-items: center;
      }
    }
    /* ══════════════════════════════════════════════════════════
       WHATSAPP FAB
    ══════════════════════════════════════════════════════════ */
    .wa-fab {
      position: fixed; bottom: max(20px, env(safe-area-inset-bottom)); right: 20px; z-index: 200;
      width: 56px; height: 56px;
      background: var(--green); border-radius: 0;
      display: flex; align-items: center; justify-content: center;
      box-shadow: none;
      border: 2px solid var(--black);
      color: var(--white);
      transition: background var(--t), color var(--t), border-color var(--t), transform var(--t), opacity 0.3s var(--ease);
      /* Escondido por padrão, JS adiciona .is-visible */
      opacity: 0; pointer-events: none;
    }
    .wa-fab.is-visible {
      opacity: 1; pointer-events: all;
    }
    .wa-fab:hover {
      background: var(--black);
      border-color: var(--black);
      transform: none;
    }
    @media (min-width: 768px) {
      .wa-fab { width: 68px; height: 68px; bottom: max(32px, env(safe-area-inset-bottom)); right: 32px; }
    }
