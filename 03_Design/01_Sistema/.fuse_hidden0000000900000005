      border-top: 1px solid var(--gray-300);
    }
    .about-metric:last-child { border-bottom: 1px solid var(--gray-300); }
    .metric-value {
      font-size: clamp(40px, 6vw, 56px);
      font-weight: 800; letter-spacing: -0.03em;
      color: var(--black); line-height: 1;
      margin-bottom: 8px;
    }
    .metric-desc {
      font-size: 16px; font-weight: 400;
      color: var(--gray-600); line-height: 1.5;
    }
    @media (min-width: 768px) {
      .section-about { padding: 96px 0; }
      .about-metrics {
        flex-direction: row;
        border-top: 1px solid var(--gray-300);
        border-bottom: 1px solid var(--gray-300);
      }
      .about-metric {
        flex: 1; padding: 48px 48px;
        border-top: none; border-bottom: none;
        border-right: 1px solid var(--gray-300);
      }
      .about-metric:first-child { padding-left: 0; }
      .about-metric:last-child { border-right: none; padding-right: 0; }
    }
    /* ══════════════════════════════════════════════════════════
       FAQ
    ══════════════════════════════════════════════════════════ */
    .section-faq {
      background: var(--off-white);
      padding: 64px 0;
      border-bottom: 1px solid var(--gray-300);
    }
    .faq-list { max-width: 800px; }
    .faq-item { border-bottom: 1px solid var(--gray-300); }
    .faq-item:first-child { border-top: 1px solid var(--gray-300); }
    /* Suporte a conteúdo enriquecido dentro da resposta — mantém tipografia do landing */
    .faq-answer + .faq-answer { margin-top: 16px; }
    .faq-answer ol, .faq-answer ul {
      margin: 16px 0;
      padding-left: 24px;
      list-style: decimal;
    }
    .faq-answer ul { list-style: disc; }
    .faq-answer li {
      margin-bottom: 14px;
      line-height: 1.7;
      padding-left: 4px;
    }
    .faq-answer li strong {
      display: inline;
      color: var(--black);
      font-weight: 700;
    }
    .faq-answer .faq-callout {
      margin-top: 20px;
      padding: 16px 20px;
      background: var(--off-white);
      border-left: 3px solid var(--green);
      font-size: 15px;
      line-height: 1.6;
      color: var(--gray-600);
    }
    .faq-answer .faq-callout strong { color: var(--black); }
    .faq-answer .faq-highlight {
      display: block;
      font-size: 18px;
      font-weight: 700;
      color: var(--black);
      margin: 0 0 12px;
    }
    .faq-answer .faq-highlight em {
      font-style: normal;
      color: var(--green);
    }
    .faq-btn {
      width: 100%; display: flex; justify-content: space-between;
      align-items: center; gap: 24px;
      padding: 32px 0; text-align: left;
      background: none; cursor: pointer;
    }
    .faq-question {
      font-size: 20px; font-weight: 600; color: var(--black);
      line-height: 1.3; transition: color var(--t);
    }
    .faq-btn:hover .faq-question { color: var(--gray-600); }
    .faq-indicator {
      width: 32px; height: 32px; flex-shrink: 0;
      border: 2px solid var(--black);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 300; color: var(--black); line-height: 1;
      transition: background var(--t), color var(--t), transform var(--t);
    }
    .faq-item.open .faq-indicator {
      background: var(--black); color: var(--white);
      transform: rotate(45deg);
    }
    .faq-body {
      height: 0; overflow: hidden;
      transition: height var(--t);
    }
    .faq-answer {
      font-size: 18px; font-weight: 400;
      line-height: 1.75; color: var(--gray-600);
      padding-bottom: 28px; max-width: 68ch;
    }
    @media (min-width: 768px) { .section-faq { padding: 96px 0; } }
