    /* ══════════════════════════════════════════════════════════
       SOBRE
    ══════════════════════════════════════════════════════════ */
    .section-about {
      background: var(--off-white);
      padding: 64px 0;
      border-top: 1px solid var(--gray-300);
      border-bottom: 1px solid var(--gray-300);
    }
    .about-text {
      max-width: 640px;
      font-size: 17px; font-weight: 400;
      line-height: 1.7; color: var(--gray-600);
      margin-bottom: 40px;
    }
    @media (min-width: 768px) {
