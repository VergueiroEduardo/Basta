<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Basta. — Chega de dívida.</title>
  <meta name="description" content="Plataforma de reestruturação financeira. Analisamos sua situação real, identificamos abusos e construímos um caminho concreto para você retomar o controle da sua vida financeira." />
  <meta name="theme-color" content="#FFFFFF" />
  <!-- BASTA FOUNDATION INJECTED -->
  <link rel="stylesheet" href="_foundation/tokens.css" />
  <link rel="stylesheet" href="_foundation/reset.css" />
  <link rel="stylesheet" href="_foundation/responsive.css" />
  <link rel="stylesheet" href="_foundation/animations.css" />
  <link rel="stylesheet" href="_foundation/typography.css" />
  <link rel="stylesheet" href="_foundation/layout.css" />
  <link rel="stylesheet" href="_foundation/grid.css" />
  <link rel="stylesheet" href="_components/logo.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
    /* ── RESET ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }    body {
      font-family: var(--f);
      font-size: 18px;
      line-height: 1.6;
      color: var(--black);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
      overflow-x: clip;
    }    img { display: block; max-width: 100%; }
    :where(button, a, input, select, textarea) { border-radius: 0; }
    /* ── ACESSIBILIDADE ─────────────────────────────────────── */
    .skip-link {
      position: absolute; top: -6rem; left: var(--px);
      background: var(--green); color: var(--white);
      font-size: 14px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 14px 24px; z-index: 9999; transition: top var(--t);
    }
    .skip-link:focus { top: 1rem; }/* ── QUEBRAS DE LINHA CONTROLADAS POR BREAKPOINT ─────────── */
    /* br.d-break: invisível no mobile, ativo no desktop          */
    br.d-break { display: none; }
    @media (min-width: 768px) { br.d-break { display: inline; } }
    /* br.m-break: ativo no mobile, invisível no desktop          */
    br.m-break { display: inline; }
    @media (min-width: 768px) { br.m-break { display: none; } }
    /* ── LAYOUT ─────────────────────────────────────────────── */
    /* .container local removido — usa o canônico de _foundation/grid.css
       (padding-inline progressivo 16/24/32 + safe-area-inset) */
    /* ── TIPOGRAFIA BASE ─────────────────────────────────────── */
    .label {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--gray-600);
    }
    /* ── BOTÕES ─────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--f); font-size: 15px; font-weight: 700;
      letter-spacing: 0.04em; text-transform: uppercase;
      padding: 18px 36px; min-height: 56px;
      transition: background var(--t), color var(--t), transform var(--t), border-color var(--t);
      border: none; cursor: pointer;
      border-radius: 0;
    }
    @media (min-width: 768px) {
      .btn { font-size: 16px; padding: 20px 48px; min-height: 60px; }
    }
    .btn-primary {
      background: var(--green); color: var(--white);
    }
    .btn-primary:hover {
      background: var(--black);
    }
    .btn-primary:active { transform: scale(0.98); }
    .btn-outline-black {
      background: transparent; color: var(--black);
      border: 2px solid var(--black);
    }
    .btn-outline-black:hover { background: var(--black); color: var(--white); }
    .btn-outline-white {
      background: transparent; color: var(--white);
      border: 2px solid var(--white);
    }
    .btn-outline-white:hover { background: var(--white); color: var(--black); }
    /* ── LOGOS ──────────────────────────────────────────────── */
    /* Logo em fundo claro: letras #000000, ponto sempre #bdc0ac */
    .logo-svg { display: block; width: auto; }
    .logo-link { display: inline-flex; align-items: center; }
    .logo-link:hover { opacity: 0.8; transition: opacity var(--t); }
    /* ══════════════════════════════════════════════════════════
       HEADER
    ══════════════════════════════════════════════════════════ */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--black);
      border-bottom: none;
    }
    .header-inner {
      display: flex; align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    /* Grupo direito: dois blocos visuais separados */
    .header-right {
      display: none;
      align-items: center; gap: 0;
    }
    /* Bloco 1: Nav desktop */
    .header-nav {
      display: flex;
      align-items: center; gap: 20px;
      padding-right: 32px;
      border-right: 1px solid color-mix(in srgb, var(--white) 15%, transparent);
      margin-right: 32px;
    }
    .header-nav a {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: color-mix(in srgb, var(--white) 55%, transparent); position: relative;
      padding-bottom: 2px;
    }
    .header-nav a::after {
      content: ''; position: absolute; bottom: -1px; left: 0;
      width: 0; height: 1px; background: var(--white);
      transition: width var(--t);
    }
    .header-nav a:hover { color: var(--white); }
    .header-nav a:hover::after { width: 100%; }
    /* Bloco 2: Header actions desktop */
    .header-actions {
      display: flex;
      align-items: center; gap: 16px;
    }
    .btn-header-login {
      font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--white); border: 2px solid var(--white);
      padding: 10px 24px; min-height: 48px; display: flex; align-items: center;
      transition: background var(--t), color var(--t);
    }
    .btn-header-login:hover { background: var(--white); color: var(--black); }
    .btn-header-cta {
      font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--white); background: var(--green);
      padding: 10px 24px; min-height: 48px; display: flex; align-items: center;
      transition: background var(--t), transform var(--t);
    }
    .btn-header-cta:hover { background: var(--black); transform: none; }
    /* Hamburger mobile */
    .hamburger {
      display: flex; flex-direction: column; justify-content: center;
      gap: 5px; width: 48px; height: 48px;
      padding: 12px; cursor: pointer;
    }
    .hamburger span {
      display: block; height: 2px; background: var(--white);
      transition: transform var(--t), opacity var(--t);
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    /* Mobile nav overlay */
    .mobile-nav {
      position: fixed; inset: 0; z-index: 99;
      background: var(--black);
      display: flex; flex-direction: column;
      padding: 88px var(--px) var(--px);
      opacity: 0; pointer-events: none;
      transform: translateY(-8px);
      transition: opacity var(--t), transform var(--t);
    }
    .mobile-nav.open {
      opacity: 1; pointer-events: all; transform: translateY(0);
    }
    .mobile-nav a {
      font-size: 36px; font-weight: 800; color: var(--white);
      letter-spacing: -0.02em; border-bottom: 1px solid color-mix(in srgb, var(--white) 10%, transparent);
      padding: 20px 0; display: block;
      transition: color var(--t);
    }
    .mobile-nav a:hover { color: var(--gray-300); }
    /* Logo tokens (sem cores inline) */
    .logo-svg-lg { height: 36px; }
    .logo-svg-md { height: 48px; }
    @media (min-width: 768px) { .logo-svg-md { height: 80px; } }
    .logo-fill { fill: var(--white); }
    .logo-dot { fill: var(--white); }
    /* Cross-fade entre logo do hero e logo do header conforme o usuário rola.
       Curva: cubic-bezier custom para entrada elegante (out + slight overshoot avoidance).
       Duração: 480ms — devagar o bastante para ser percebido, rápido o bastante para não atrasar. */
    .header-logo {
      opacity: 0;
      transform: translateY(-12px);
      transition: opacity 0.48s cubic-bezier(0.22, 0.61, 0.36, 1),
                  transform 0.48s cubic-bezier(0.22, 0.61, 0.36, 1);
      pointer-events: none;
      will-change: opacity, transform;
    }
    .header-logo.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    /* Estado inicial via classe legado: igual ao default acima */
    .header-logo.is-hidden { opacity: 0; transform: translateY(-12px); pointer-events: none; }
    /* Hero logo: cross-fade simétrico ao header-logo */
    .hero-logo {
      transition: opacity 0.48s cubic-bezier(0.22, 0.61, 0.36, 1),
                  transform 0.48s cubic-bezier(0.22, 0.61, 0.36, 1);
      will-change: opacity, transform;
    }
    .hero-logo.is-fading {
      opacity: 0;
      transform: translateY(-8px) scale(0.96);
    }
    /* Logo grande na hero — canto inferior direito, presença brutal */
    /* Logo do hero — branco, alinhado pelo TOPO ao TOPO do botão "Começar agora".
       Anchored no .hero-actions (que envolve o botão), top:0 garante a coincidência. */
    .hero-content { position: relative; }
    .hero-actions { position: relative; }
    .hero-logo {
      /* Mobile: escondido (logo aparece grande no header mobile já) */
      display: none;
    }
    @media (min-width: 900px) {
      .hero-logo {
        display: block;
        position: absolute;
        top: 0;                                /* topo do logo = topo do .hero-actions = topo do botão */
        left: calc(100% + clamp(16px, 2vw, 32px));   /* ~1 coluna de respiro do CTA — composição coesa */
        height: clamp(140px, 18vw, 240px);
        width: auto;
        color: var(--white);
        opacity: 0.95;
        z-index: 2;
        pointer-events: none;
      }
    }
    .hero-logo path,
    .hero-logo use { fill: var(--white) !important; }
    .mobile-nav-actions {
      margin-top: 40px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding-top: 32px;
      border-top: 1px solid color-mix(in srgb, var(--white) 10%, transparent);
    }
    .mobile-nav-actions .btn {
      width: 100%;
      justify-content: center;
      min-height: 52px;
      font-size: 14px;
    }
    /* Desktop breakpoint: show header-right, hide hamburger */
    @media (min-width: 900px) {
      .header-inner { height: 84px; }
      .header-right { display: flex; }
      .hamburger { display: none; }
      .mobile-nav { display: none; }
    }
    /* ══════════════════════════════════════════════════════════
       HERO — full-bleed background image
    ══════════════════════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      align-items: center;
      background: var(--black); /* fallback enquanto imagem carrega */
      border-bottom: none;
      overflow: hidden;
    }
    /* Camada de imagem */
    .hero-bg {
      position: absolute; inset: 0;
    }
    .hero-bg-img {
      width: 100%; height: 100%;
      object-fit: cover;
      /* mantém rosto + mão visíveis em qualquer viewport */
      object-position: center 20%;
      display: block;
    }
    /* Overlay escuro — topo 100% preto (fusão com header), gradiente para overlay */
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        to bottom,
        var(--black) 0%,
        color-mix(in srgb, var(--black) 72%, transparent) 15%,
        color-mix(in srgb, var(--black) 72%, transparent) 100%
      );
    }
    /* Mobile: overlay mais denso */
    @media (max-width: 767px) {
      .hero-overlay {
        background: linear-gradient(
          to bottom,
          var(--black) 0%,
          color-mix(in srgb, var(--black) 78%, transparent) 15%,
          color-mix(in srgb, var(--black) 78%, transparent) 100%
        );
      }
    }
    /* Conteúdo sobre o fundo */
    .hero-content {
      position: relative; z-index: 1;
      padding: 32px 0;
      max-width: 680px;
    }
    /* Kicker acima do headline */
    .hero-kicker {
      display: flex; align-items: center; gap: 16px;
      margin-bottom: 32px;
    }
    .hero-kicker-dot {
      width: 8px; height: 8px;
      background: var(--gray-300); border-radius: 0;
      flex-shrink: 0;
    }
    .hero-kicker-text {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: color-mix(in srgb, var(--white) 55%, transparent);
    }
    /* Headline — protagonista da página */
    .hero-headline {
      font-size: clamp(44px, 10vw, 88px);
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: var(--white);
      margin-bottom: 28px;
    }
    /* "sua" com underline em sage */
    .hero-headline .hl-sua {
      text-decoration: underline;
      text-decoration-color: var(--gray-300);
      text-underline-offset: 0.1em;
      text-decoration-thickness: 0.035em;
    }
    .hero-sub {
      font-size: clamp(17px, 2.2vw, 20px); font-weight: 400;
      line-height: 1.7; color: color-mix(in srgb, var(--white) 72%, transparent);
      max-width: 48ch; margin-bottom: 32px;
    }
    .hero-actions {
      display: flex;
      flex-direction: column;
      gap: 16px; align-items: flex-start; margin-bottom: 32px;
    }
    .hero-actions .btn { width: 100%; justify-content: center; }
    @media (min-width: 600px) {
      .hero-actions { flex-direction: row; flex-wrap: wrap; gap: 16px; align-items: center; }
      .hero-actions .btn { width: auto; }
    }
    .hero-link-secondary {
      font-size: 16px; font-weight: 600;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--white); display: flex; align-items: center; gap: 6px;
      min-height: 48px; padding: 4px 0;
      border-bottom: 1px solid color-mix(in srgb, var(--white) 35%, transparent);
      transition: color var(--t), border-color var(--t);
    }
    .hero-link-secondary:hover { color: var(--gray-300); border-color: var(--gray-300); }
    /* Trust signals inline */
    .hero-trust {
      display: flex; flex-wrap: wrap; gap: 0;
    }
    .trust-signal {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: color-mix(in srgb, var(--white) 45%, transparent);
      padding-right: 20px; margin-right: 20px;
      border-right: 1px solid color-mix(in srgb, var(--white) 18%, transparent);
    }
    .trust-signal:last-child { border-right: none; padding-right: 0; margin-right: 0; }
    @media (max-width: 480px) {
      .hero-content { padding: 32px 0; }
      .hero-headline { font-size: clamp(38px, 12vw, 56px); }
    }
    /* ══════════════════════════════════════════════════════════
       TRUST BAR
       "Sem ícones. Só texto. O texto é o ícone."
    ══════════════════════════════════════════════════════════ */
    .trust-bar {
      background: var(--off-white);
      border-top: 1px solid var(--gray-300);
      border-bottom: 1px solid var(--gray-300);
    }
    .trust-bar-inner {
      display: flex;
      flex-direction: column;
    }
    .trust-col {
      padding: 32px 0;
      border-bottom: 1px solid var(--gray-300);
    }
    .trust-col:last-child { border-bottom: none; }
    .trust-col-value {
      font-size: clamp(32px, 5vw, 42px);
      font-weight: 800; letter-spacing: -0.03em;
      color: var(--black); line-height: 1;
      margin-bottom: 8px;
    }
    .trust-col-desc {
      font-size: 16px; font-weight: 400;
      color: var(--gray-600); line-height: 1.5;
    }
    @media (min-width: 768px) {
      .trust-bar-inner {
        flex-direction: row;
        border-top: none;
        border-bottom: none;
      }
      .trust-col {
        flex: 1; padding: 40px 48px;
        border-bottom: none;
        border-right: 1px solid var(--gray-300);
      }
      .trust-col:first-child { padding-left: 0; }
      .trust-col:last-child { border-right: none; padding-right: 0; }
    }
    /* ══════════════════════════════════════════════════════════
       COMO FUNCIONA
       Lista vertical com números oversized como elemento visual.
       Hover: número → sage, fundo → off-white.
    ══════════════════════════════════════════════════════════ */
    .section-steps {
      background: var(--white);
      padding: 64px 0 32px 0;
    }
    .section-heading {
      font-size: clamp(48px, 7vw, 80px);
      font-weight: 800; line-height: 1.02;
      letter-spacing: -0.03em; color: var(--black);
      margin-bottom: 40px;
      text-wrap: balance;
    }
    /* ── EYEBROW — componente reutilizável ──────────────────── */
    .section-eyebrow {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--gray-600); margin-bottom: 40px;
      display: flex; align-items: center; gap: 16px;
    }
    .section-eyebrow::after {
      content: ''; flex: 1; height: 1px;
      background: var(--gray-300);
    }
    /* Variante sobre fundo escuro */
    .section-eyebrow--dark {
      color: var(--green);
    }
    .section-eyebrow--dark::after {
      background: rgba(255,255,255,0.15);
    }
    .section-heading-sm {
      font-size: clamp(40px, 5.5vw, 64px);
      font-weight: 800; line-height: 1.02;
      letter-spacing: -0.03em; color: var(--black);
      margin-bottom: 40px;
      text-wrap: balance;
    }
    /* ── JOURNEY BAR ──────────────────────────────────────── */
    .journey-bar {
      background: var(--off-white);
      border-radius: 0;
      padding: 32px var(--px) 28px;
      margin-bottom: 48px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      /* Background full-bleed: estende a cor até as extremidades da viewport
         sem afetar o layout interno (padding, scroll, conteúdo respeitam o container). */
      box-shadow: 100vmax 0 0 var(--off-white), -100vmax 0 0 var(--off-white);
      clip-path: inset(0 -100vmax);
    }
    .journey-bar::-webkit-scrollbar { display: none; }
    .journey-track {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      position: relative;
      min-width: 560px;
    }
    /* Linha conectora horizontal */
    .journey-track::before {
      content: '';
      position: absolute;
      top: 24px;
      left: 32px;
      right: 32px;
      height: 2px;
      background: var(--gray-300);
      z-index: 0;
    }
    .journey-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 1;
      flex: 1;
      min-width: 0;
    }
    .journey-num {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 2px solid var(--black);
      background: var(--off-white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--f);
      font-size: 18px;
      font-weight: 800;
      color: var(--black);
      flex-shrink: 0;
    }
    .journey-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--gray-600);
      text-align: center;
      max-width: 110px;
      line-height: 1.3;
    }
    @media (min-width: 768px) {
      .journey-bar {
        padding: 40px var(--px-lg) 36px;
        margin: 0 calc(-1 * var(--px-lg)) 56px;
        overflow: visible;
      }
      .journey-track { min-width: 0; }
      .journey-num {
        width: 52px;
        height: 52px;
        font-size: 20px;
      }
      .journey-track::before {
        top: 26px;
        left: 40px;
        right: 40px;
      }
      .journey-label {
        font-size: 14px;
        max-width: 130px;
      }
    }
    /* Journey step como link */
    a.journey-step {
      text-decoration: none;
      color: inherit;
      transition: transform 180ms var(--ease);
    }
    a.journey-step:hover { transform: translateY(-2px); }
    a.journey-step:hover .journey-num {
      background: var(--black);
      color: var(--white);
    }
    /* ── STEPS CTA (rodapé da seção como funciona) ────────── */
    .steps-cta {
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
      margin-top: 48px;
    }
    @media (min-width: 600px) {
      .steps-cta {
        flex-direction: row;
        align-items: center;
        gap: 16px;
      }
    }
    .steps-link-secondary {
      font-size: 16px; font-weight: 600;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--black);
      display: flex; align-items: center; gap: 6px;
      min-height: 48px; padding: 4px 0;
      border-bottom: 1px solid var(--gray-300);
      transition: color var(--t), border-color var(--t);
    }
    .steps-link-secondary:hover {
      color: var(--gray-600);
      border-color: var(--gray-600);
    }
    /* ── STEPS LIST ──────────────────────────────────────── */
    .steps-list {
      list-style: none;
    }
    .step {
      scroll-margin-top: 24px;
    }
    .step.is-highlighted {
      background: var(--off-white);
      animation: step-flash 1.2s var(--ease) both;
    }
    .step.is-highlighted .step-num { color: var(--green); opacity: 1; }
    @keyframes step-flash {
      0%   { background: color-mix(in srgb, var(--green) 10%, var(--off-white)); }
      100% { background: transparent; }
    }
    .step {
      /* Mobile-first: stack — número no topo, conteúdo full-width.
         Libera o desc para usar a largura total da viewport, melhorando
         medida de leitura (~50–60 caracteres por linha). */
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 24px 0;
      border-top: 1px solid var(--gray-300);
      align-items: start;
      /* Transições: fundo + sombra esquerda */
      transition: background var(--t);
      margin: 0 calc(-1 * var(--px));
      padding-left: var(--px);
      padding-right: var(--px);
    }
    .step:last-child { border-bottom: 1px solid var(--gray-300); }
    .step:hover {
      background: var(--off-white);
      cursor: default;
    }
    .step-num {
      font-size: clamp(48px, 13vw, 64px);
      font-weight: 800; line-height: 0.85;
      color: var(--gray-300);
      letter-spacing: -0.04em;
      transition: color var(--t), opacity var(--t);
      user-select: none;
    }
    .step:hover .step-num { color: var(--green); opacity: 1; }
    /* Bloco de texto desloca levemente no hover */
    .step-content {
      transition: transform var(--t);
      max-width: 60ch;
    }
    .step:hover .step-content { transform: none; }
    .step-title {
      font-size: clamp(19px, 2.2vw, 22px);
      font-weight: 700; color: var(--black);
      letter-spacing: -0.01em; line-height: 1.25;
      margin-bottom: 8px;
      text-wrap: balance;
    }
    .step-desc {
      font-size: 17px; font-weight: 400;
      color: var(--gray-600); line-height: 1.6;
      /* Otimiza quebras de parágrafo: evita viúvas/órfãs e linhas curtas
         desbalanceadas. Combina com max-width: 60ch do .step-content. */
      text-wrap: pretty;
    }
    @media (min-width: 768px) {
      .section-steps { padding: 96px 0 48px 0; }
      .step {
        /* Tablet+: side-by-side — número como âncora visual em coluna fixa */
        grid-template-columns: 120px 1fr;
        gap: 40px; padding: 32px 0;
        margin: 0 calc(-1 * var(--px-lg));
        padding-left: var(--px-lg);
        padding-right: var(--px-lg);
      }
      .step-num {
        font-size: clamp(56px, 7vw, 80px);
      }
      .step-title {
        line-height: 1.2;
      }
      .step-desc {
        line-height: 1.65;
      }
    }
    /* ══════════════════════════════════════════════════════════
       MANIFESTO
       Coração emocional da página. Preto total, texto branco.
       Frases de impacto em peso máximo.
    ══════════════════════════════════════════════════════════ */
    .section-manifesto {
      background: var(--black);
      padding: 80px 0;
    }
    .manifesto-inner { max-width: 800px; }
    /* manifesto eyebrow: usa .section-eyebrow--dark */
    .manifesto-heading {
      font-size: clamp(40px, 5.5vw, 64px);
      font-weight: 800; line-height: 1.02;
      letter-spacing: -0.03em; color: var(--white);
      margin-bottom: 48px;
      text-wrap: balance;
    }
    .manifesto-body {
      font-size: 17px; font-weight: 400;
      line-height: 1.75; color: color-mix(in srgb, var(--white) 60%, transparent);
    }
    @media (min-width: 768px) {
      .manifesto-body { font-size: 20px; line-height: 1.8; }
    }
    .manifesto-body p + p { margin-top: 24px; }
    .manifesto-body strong {
      color: var(--white); font-weight: 700;
    }
    .manifesto-sig {
      margin-top: 80px; padding-top: 48px;
      border-top: 1px solid color-mix(in srgb, var(--white) 10%, transparent);
      display: flex; align-items: baseline; gap: 24px; flex-wrap: wrap;
    }
    .sig-word {
      font-size: clamp(48px, 7vw, 96px);
      font-weight: 800; color: var(--white);
      letter-spacing: -0.04em; line-height: 1;
    }
    .sig-dot-green { color: var(--green); }
    /* Pontos brancos: presença tipográfica, somem contra o fundo escuro */
    .sig-dot-white { color: var(--white); }
    @media (min-width: 768px) { .section-manifesto { padding: 160px 0; } }
    /* ══════════════════════════════════════════════════════════
       OPEN FINANCE — seção de confiança e segurança
    ══════════════════════════════════════════════════════════ */
    .section-openfinance {
      background: var(--black);
      color: var(--white);
      padding: 64px 0;
    }
    @media (min-width: 768px) {
      .section-openfinance { padding: 96px 0; }
