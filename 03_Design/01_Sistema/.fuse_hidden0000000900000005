  <script>
    // ── SCROLL TO TOP ON LOAD (limpa hash para abrir na hero) ──
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname);
      window.scrollTo(0, 0);
    }

    // ── MOBILE MENU ─────────────────────────────────────────
    var menuBtn = document.getElementById('menu-btn');
    var mobileNav = document.getElementById('mobile-nav');

    // Função para coletar focusable elements dentro do menu
    function getFocusableElements() {
      return Array.from(mobileNav.querySelectorAll(
        'a, button, input[type="text"], input[type="email"], input[type="button"], [tabindex]:not([tabindex="-1"])'
      )).filter(function(el) {
        return el.offsetParent !== null; // visível
      });
    }

    // Função para fechar o menu
    function closeMenu() {
      mobileNav.classList.remove('open');
      menuBtn.classList.remove('open');
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.setAttribute('aria-label', 'Abrir menu de navegação');
      document.body.style.overflow = '';
    }

    // Função para abrir o menu
    function openMenu() {
      mobileNav.classList.add('open');
      menuBtn.classList.add('open');
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.setAttribute('aria-label', 'Fechar menu de navegação');
      document.body.style.overflow = 'hidden';
    }

    // Toggle do menu ao clicar no hamburger
    menuBtn.addEventListener('click', function() {
      if (mobileNav.classList.contains('open')) {
        closeMenu();
      } else {
        openMenu();
        // Move foco para o primeiro elemento focusável
        setTimeout(function() {
          var focusable = getFocusableElements();
          if (focusable.length > 0) {
            focusable[0].focus();
          }
        }, 0);
      }
    });

    // Fechar menu ao clicar em um link
    mobileNav.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        closeMenu();
        menuBtn.focus();
      });
    });

    // Focus trap dentro do menu
    mobileNav.addEventListener('keydown', function(e) {
      if (e.key !== 'Tab' || !mobileNav.classList.contains('open')) {
        return;
      }

      var focusable = getFocusableElements();
      if (focusable.length === 0) return;

      var activeEl = document.activeElement;
      var activeIndex = focusable.indexOf(activeEl);

      if (e.shiftKey) {
        // Shift+Tab: volta pro anterior (ou último se estiver no primeiro)
        e.preventDefault();
        var prevIndex = activeIndex <= 0 ? focusable.length - 1 : activeIndex - 1;
        focusable[prevIndex].focus();
      } else {
        // Tab: vai pro próximo (ou primeiro se estiver no último)
        e.preventDefault();
        var nextIndex = activeIndex >= focusable.length - 1 ? 0 : activeIndex + 1;
        focusable[nextIndex].focus();
      }
    });

    // Escape fecha o menu
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && mobileNav.classList.contains('open')) {
        closeMenu();
        menuBtn.focus();
      }
    });
    // ── SCROLL: cross-fade hero-logo → header-logo + WhatsApp FAB ─────
    // Quando o bloco do CTA (.hero-actions) sai da viewport, o logo do hero
    // some com slide+scale e o logo do header surge com slide vertical.
    // Transição simétrica de 480ms.
    (function() {
      var sentinel   = document.querySelector('.hero-actions');
      var heroLogo   = document.querySelector('.hero-logo');
      var headerLogo = document.querySelector('.header-logo');
      var waFab      = document.querySelector('.wa-fab');

      if (!sentinel || !headerLogo) return;

      // Estado inicial limpo
      headerLogo.classList.remove('is-hidden');
      headerLogo.classList.remove('is-visible');

      var show = function() {
        headerLogo.classList.add('is-visible');
        if (heroLogo)  heroLogo.classList.add('is-fading');
        if (waFab)     waFab.classList.add('is-visible');
      };
      var hide = function() {
        headerLogo.classList.remove('is-visible');
        if (heroLogo)  heroLogo.classList.remove('is-fading');
        if (waFab)     waFab.classList.remove('is-visible');
      };

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          // Sentinel visível na viewport: hero ainda está em cena → header logo escondido.
          // Sentinel saiu (rolou para cima): header logo aparece.
          if (entry.isIntersecting) {
            hide();
          } else {
            show();
          }
        });
      }, {
        threshold: 0,
        // Considera "fora" quando o sentinel passa para cima do topo da viewport
        rootMargin: '-80px 0px 0px 0px'
      });

      observer.observe(sentinel);
    })();

    // ── JOURNEY BAR → SCROLL TO CENTER ──────────────────────
    document.querySelectorAll('.journey-step').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var targetId = this.getAttribute('href').substring(1);
        var target = document.getElementById(targetId);
        if (!target) return;
        // Remove highlight anterior
        document.querySelectorAll('.step.is-highlighted').forEach(function(s) {
          s.classList.remove('is-highlighted');
        });
        // Scroll suave centralizado na viewport
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        // Aplica highlight via classe (sem depender de :target que força scroll ao topo)
        target.classList.add('is-highlighted');
        // Remove highlight após a animação e limpa hash
        setTimeout(function() {
          target.classList.remove('is-highlighted');
          history.replaceState(null, '', window.location.pathname);
        }, 1400);
      });
    });

    // ── FAQ ACCORDION ────────────────────────────────────────
    document.querySelectorAll('.faq-item').forEach(function(item) {
      var btn  = item.querySelector('.faq-btn');
      var body = item.querySelector('.faq-body');
      btn.addEventListener('click', function() {
        var isOpen = item.classList.contains('open');
        // Fecha todos
        document.querySelectorAll('.faq-item').forEach(function(i) {
          i.classList.remove('open');
          i.querySelector('.faq-body').style.height = '0';
          i.querySelector('.faq-btn').setAttribute('aria-expanded', 'false');
        });
        // Abre o clicado se não estava aberto
        if (!isOpen) {
          item.classList.add('open');
          body.style.height = body.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
