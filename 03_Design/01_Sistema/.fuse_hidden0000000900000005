      letter-spacing: -0.01em; line-height: 1.2;
      margin-bottom: 8px;
    }
    .of-block-desc {
      font-size: 16px; font-weight: 400;
      color: rgba(255,255,255,0.6); line-height: 1.5;
      max-width: 480px;
    }
    @media (min-width: 768px) {
      .of-blocks {
